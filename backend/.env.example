# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contracts
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=contracts

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_AUTH_TOKEN=dev-token

# JWT Authentication (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE-THIS-SECRET-IN-PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-YOUR-KEY-HERE
OPENAI_MODEL=gpt-4o

# Langfuse (optional - for LLM observability)
LANGFUSE_SECRET_KEY = "sk-lf-YOUR-SECRET-KEY-HERE"
LANGFUSE_PUBLIC_KEY = "pk-lf-YOUR-PUBLIC-KEY-HERE"
LANGFUSE_BASE_URL = "https://cloud.langfuse.com"

# File Storage
UPLOAD_DIR=./storage/uploads
PROCESSED_DIR=./storage/processed

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
