# CLM deploy environments — local config (gitignored as environments.env)
#
# Copy this file to environments.env and fill in your values:
#     cp environments.env.example environments.env
#
# environments.env is loaded by ./env-deploy.sh to resolve the target host,
# SSH key, and (optional) .env file path for each environment. Both env names
# (prod and staging) are independent — you can leave staging blank until you
# provision it.
#
# The file is gitignored — never commit it. Two people on the same team
# typically keep their own copy.

# -----------------------------------------------------------------------------
# Production — the live AWS demo box
# -----------------------------------------------------------------------------
PROD_IP=52.21.204.211
PROD_KEY=~/.ssh/clm-demo-key.pem
# Optional: path to a local .env file that should be synced to the prod box on
# every deploy. Leave blank to keep the .env file managed manually on the box.
PROD_ENV_FILE=

# -----------------------------------------------------------------------------
# Staging — the Lightsail $20 plan for testing migrations & changes safely
# -----------------------------------------------------------------------------
STAGING_IP=
STAGING_KEY=~/.ssh/clm-staging-key.pem
STAGING_ENV_FILE=
