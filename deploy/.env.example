# CLM Platform - Production Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED - Must be set before deployment
# ===========================================

# Database credentials
POSTGRES_USER=clm
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=clm

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-YOUR-KEY-HERE

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# ===========================================
# OPTIONAL - Can use defaults
# ===========================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Note: CORS is configured to allow all origins by default for demo purposes.
# For production, update backend/app/config.py to restrict origins.

# ===========================================
# OPTIONAL - Public URL (for email links)
# ===========================================
PUBLIC_URL=http://YOUR-SERVER-IP

# ===========================================
# OPTIONAL - AWS SES Email
# ===========================================
# For sending real emails to external users (contract sharing, invitations)
# Get credentials from AWS IAM console or use EC2 instance role
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
# SES_FROM_EMAIL=notifications@yourdomain.com
# SES_FROM_NAME=Evaluetor CLM

# ===========================================
# OPTIONAL - Langfuse Observability
# ===========================================

# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com
