---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatsBar from '../components/StatsBar.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import CTABanner from '../components/CTABanner.astro';

const icons = {
  ai: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>',
  check: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>',
  chart: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>',
  clock: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>',
  users: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>',
  shield: '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>',
};
---

<MarketingLayout title="AI-Powered Contract Intelligence" description="Evaluetor reads your contracts so you don't have to. Extract obligations, track SLAs, monitor renewals, and score vendor performance — all powered by AI.">

  <!-- Hero -->
  <Hero
    tag="Contract Intelligence"
    headline='Nobody reads contracts. <span class="text-primary-600">We built an AI that does.</span>'
    subheadline="Upload any PDF. Get every obligation, risk, deadline, and SLA extracted in minutes — not months."
    primaryCTA={{ text: 'Try it free', href: '/contact' }}
    secondaryCTA={{ text: 'See how it works', href: '/product' }}
  />

  <!-- Stats -->
  <StatsBar stats={[
    { value: '90%', label: 'Less time reviewing' },
    { value: '3-5x', label: 'More SLA credits found' },
    { value: '95%', label: 'Fewer missed deadlines' },
    { value: 'Hours', label: 'To first insight' },
  ]} />

  <!-- Core Capabilities -->
  <section class="section-padding">
    <div class="container-narrow">
      <SectionHeading
        tag="Capabilities"
        title="What Evaluetor does"
        subtitle="Most CLM tools stop at storage. We start with intelligence."
      />
      <FeatureGrid>
        <FeatureCard
          title="Contract Intelligence"
          description="AI extracts metadata, clauses, obligations, and risks from every contract automatically. 30 clause types, 10 risk categories, full semantic search."
          icon={icons.ai}
          href="/features/contract-intelligence"
        />
        <FeatureCard
          title="Obligation Tracking"
          description="Never miss a deadline. Track every obligation with RAG status indicators, owner assignment, compliance evidence, and automated alerts."
          icon={icons.check}
          href="/features/obligation-tracking"
        />
        <FeatureCard
          title="SLA Monitoring"
          description="Compare contracted SLAs against actual performance. Detect breaches, calculate service credits, and track penalties automatically."
          icon={icons.chart}
          href="/features/sla-monitoring"
        />
        <FeatureCard
          title="Renewal Management"
          description="Calendar view of all expirations. Auto-renewal detection, notice deadline calculation, and AI-powered renewal recommendations."
          icon={icons.clock}
          href="/features/renewal-management"
        />
        <FeatureCard
          title="Relationship Governance"
          description="Score vendor performance with multi-factor analysis. Track KPI perception gaps between internal and external stakeholders."
          icon={icons.users}
          href="/features/relationship-governance"
        />
        <FeatureCard
          title="Enterprise Security"
          description="SOC 2 Type II compliant. GDPR-ready with data residency options. Role-based access control, SSO, and comprehensive audit trails."
          icon={icons.shield}
          href="/platform"
        />
      </FeatureGrid>
    </div>
  </section>

  <!-- Problem Statement -->
  <section class="section-padding bg-gray-950">
    <div class="container-narrow">
      <SectionHeading
        tag="The Problem"
        title="The problem is obvious"
        subtitle="Contracts are the foundation of every business relationship. Yet nobody knows what's in them."
        dark={true}
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="text-3xl font-bold text-red-400 mb-2">60%</div>
          <p class="text-sm text-gray-400">of enterprises can't tell you what's in their contracts</p>
        </div>
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="text-3xl font-bold text-red-400 mb-2">$2M+</div>
          <p class="text-sm text-gray-400">lost annually to missed obligations</p>
        </div>
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <div class="text-3xl font-bold text-red-400 mb-2">15-30%</div>
          <p class="text-sm text-gray-400">of service credits go unclaimed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="section-padding bg-gray-950">
    <div class="container-narrow">
      <SectionHeading
        tag="Why Evaluetor"
        title="Not another CLM tool"
        subtitle="We're AI-native. Not AI-bolted-on."
        dark={true}
      />
      <ComparisonTable />
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    headline="See it for yourself"
    subtext="Upload a real contract. Watch our AI extract everything in minutes. No sales pitch required."
    buttonText="Try it free"
    buttonLink="/contact"
  />

</MarketingLayout>
