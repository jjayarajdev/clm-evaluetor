---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Coming Soon" description="Evaluetor — AI-Powered Contract Intelligence. Making your contracts Transparent, Measurable and Actionable. Coming Soon.">

<div class="relative min-h-screen bg-gray-950 overflow-hidden flex items-center justify-center">

  <!-- Animated background: floating contract clauses -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <!-- Mesh gradient blobs -->
    <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] rounded-full bg-primary-600/8 blur-[150px] animate-drift-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full bg-orange-500/6 blur-[120px] animate-drift-med"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full bg-pink-500/4 blur-[100px] animate-drift-slow"></div>

    <!-- Dot grid -->
    <div class="absolute inset-0 dot-grid opacity-20"></div>

    <!-- Floating contract document shapes -->
    <div class="contract-float contract-1">
      <div class="w-32 h-40 rounded-lg border border-primary-500/20 bg-white/[0.03] backdrop-blur-sm p-3 shadow-xl shadow-primary-500/5">
        <div class="w-10 h-1.5 bg-primary-500/30 rounded mb-2"></div>
        <div class="w-full h-1 bg-white/10 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/10 rounded mb-1.5"></div>
        <div class="w-3/4 h-1 bg-white/10 rounded mb-3"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-5/6 h-1 bg-white/8 rounded mb-3"></div>
        <div class="w-full h-1 bg-white/5 rounded mb-1.5"></div>
        <div class="w-2/3 h-1 bg-white/5 rounded"></div>
        <!-- AI scan line -->
        <div class="absolute inset-x-2 h-px bg-gradient-to-r from-transparent via-primary-400 to-transparent animate-scan"></div>
      </div>
    </div>

    <div class="contract-float contract-2">
      <div class="w-28 h-36 rounded-lg border border-orange-500/20 bg-white/[0.03] backdrop-blur-sm p-3 shadow-xl shadow-orange-500/5">
        <div class="w-8 h-1.5 bg-orange-500/30 rounded mb-2"></div>
        <div class="w-full h-1 bg-white/10 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/10 rounded mb-1.5"></div>
        <div class="w-2/3 h-1 bg-white/10 rounded mb-3"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-3/4 h-1 bg-white/8 rounded"></div>
        <div class="absolute inset-x-2 h-px bg-gradient-to-r from-transparent via-orange-400 to-transparent animate-scan-delayed"></div>
      </div>
    </div>

    <div class="contract-float contract-3">
      <div class="w-24 h-32 rounded-lg border border-primary-400/15 bg-white/[0.02] backdrop-blur-sm p-2.5 shadow-xl shadow-primary-400/5">
        <div class="w-7 h-1 bg-primary-400/25 rounded mb-2"></div>
        <div class="w-full h-0.5 bg-white/8 rounded mb-1"></div>
        <div class="w-full h-0.5 bg-white/8 rounded mb-1"></div>
        <div class="w-4/5 h-0.5 bg-white/8 rounded mb-2.5"></div>
        <div class="w-full h-0.5 bg-white/6 rounded mb-1"></div>
        <div class="w-full h-0.5 bg-white/6 rounded mb-1"></div>
        <div class="w-3/5 h-0.5 bg-white/6 rounded"></div>
      </div>
    </div>

    <div class="contract-float contract-4">
      <div class="w-20 h-28 rounded border border-orange-400/15 bg-white/[0.02] p-2">
        <div class="w-5 h-1 bg-orange-400/20 rounded mb-1.5"></div>
        <div class="w-full h-0.5 bg-white/7 rounded mb-1"></div>
        <div class="w-full h-0.5 bg-white/7 rounded mb-1"></div>
        <div class="w-3/4 h-0.5 bg-white/7 rounded mb-2"></div>
        <div class="w-full h-0.5 bg-white/5 rounded mb-1"></div>
        <div class="w-2/3 h-0.5 bg-white/5 rounded"></div>
      </div>
    </div>

    <div class="contract-float contract-5">
      <div class="w-36 h-44 rounded-lg border border-primary-500/15 bg-white/[0.02] backdrop-blur-sm p-3">
        <div class="w-12 h-1.5 bg-primary-500/25 rounded mb-2.5"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-5/6 h-1 bg-white/8 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/8 rounded mb-3"></div>
        <!-- Highlighted "clause" -->
        <div class="w-full h-2.5 bg-primary-500/15 rounded border border-primary-500/20 mb-2"></div>
        <div class="w-full h-1 bg-white/6 rounded mb-1.5"></div>
        <div class="w-full h-1 bg-white/6 rounded mb-1.5"></div>
        <div class="w-2/3 h-1 bg-white/6 rounded"></div>
      </div>
    </div>

    <!-- Floating clause tags -->
    <div class="clause-tag tag-1">Indemnification</div>
    <div class="clause-tag tag-2">SLA: 99.9% uptime</div>
    <div class="clause-tag tag-3">Auto-renewal</div>
    <div class="clause-tag tag-4">Payment: NET 30</div>
    <div class="clause-tag tag-5">Termination clause</div>
    <div class="clause-tag tag-6">Force Majeure</div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 text-center max-w-3xl mx-auto px-6">

    <!-- Logo -->
    <div class="mb-8 inline-flex items-center gap-3 px-6 py-3 rounded-full border border-primary-500/30 bg-primary-500/10 backdrop-blur-sm">
      <svg class="w-8 h-7" viewBox="0 0 218 178" fill="none">
        <path d="M 0,55 A 55,55 0 0,1 55,0 L 98,0 L 98,78 L 0,78 Z" fill="#A78BFA"/>
        <path d="M 118,0 L 163,0 A 55,55 0 0,1 218,55 L 218,78 L 118,78 Z" fill="#A78BFA"/>
        <path d="M 0,98 L 98,98 L 98,178 L 55,178 A 55,55 0 0,1 0,123 Z" fill="#A78BFA"/>
        <path d="M 118,98 L 218,98 L 218,123 A 55,55 0 0,1 163,178 L 118,178 Z" fill="#A78BFA"/>
      </svg>
      <span class="text-primary-300 font-semibold tracking-wider text-sm uppercase">Evaluetor</span>
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-[1.1] mb-6">
      Something powerful<br>
      <span class="gradient-text">is coming.</span>
    </h1>

    <!-- Subline -->
    <p class="text-lg sm:text-xl text-gray-400 leading-relaxed mb-10 max-w-2xl mx-auto">
      AI-powered contract intelligence that makes your contracts transparent, measurable, and actionable. We're putting the finishing touches on something you've never seen in CLM.
    </p>

    <!-- Animated features ticker -->
    <div class="mb-12 overflow-hidden h-8 relative">
      <div class="ticker-wrap">
        <div class="ticker">
          <span class="ticker-item text-primary-400">9 AI Agents</span>
          <span class="ticker-item text-orange-400">Obligation Tracking</span>
          <span class="ticker-item text-primary-400">SLA Monitoring</span>
          <span class="ticker-item text-orange-400">Risk Detection</span>
          <span class="ticker-item text-primary-400">Relationship Governance</span>
          <span class="ticker-item text-orange-400">Knowledge Graph</span>
          <span class="ticker-item text-primary-400">Perception Gap Scoring</span>
          <span class="ticker-item text-orange-400">Vendor Scorecards</span>
          <!-- Duplicate for seamless loop -->
          <span class="ticker-item text-primary-400">9 AI Agents</span>
          <span class="ticker-item text-orange-400">Obligation Tracking</span>
          <span class="ticker-item text-primary-400">SLA Monitoring</span>
          <span class="ticker-item text-orange-400">Risk Detection</span>
          <span class="ticker-item text-primary-400">Relationship Governance</span>
          <span class="ticker-item text-orange-400">Knowledge Graph</span>
          <span class="ticker-item text-primary-400">Perception Gap Scoring</span>
          <span class="ticker-item text-orange-400">Vendor Scorecards</span>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex items-center justify-center">
      <a href="/contact"
         class="btn-primary text-base px-8 py-3.5 group">
        Get Early Access
        <svg class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>

    <!-- Bottom tagline -->
    <p class="mt-16 text-xs text-gray-600 tracking-wide uppercase">
      AI-Powered Contract Intelligence &mdash; Rotterdam, Netherlands
    </p>
  </div>
</div>

<style>
  /* Floating contract documents */
  .contract-float {
    position: absolute;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .contract-1 { top: 8%; left: 5%; animation: float-1 18s infinite; }
  .contract-2 { top: 15%; right: 8%; animation: float-2 22s infinite; }
  .contract-3 { bottom: 20%; left: 10%; animation: float-3 20s infinite; }
  .contract-4 { bottom: 12%; right: 12%; animation: float-4 16s infinite; }
  .contract-5 { top: 45%; left: -2%; animation: float-5 24s infinite; }

  @keyframes float-1 {
    0%, 100% { transform: translateY(0) rotate(-3deg); opacity: 0.6; }
    50% { transform: translateY(-30px) rotate(2deg); opacity: 0.8; }
  }
  @keyframes float-2 {
    0%, 100% { transform: translateY(0) rotate(4deg); opacity: 0.5; }
    50% { transform: translateY(-25px) rotate(-2deg); opacity: 0.7; }
  }
  @keyframes float-3 {
    0%, 100% { transform: translateY(0) rotate(-2deg); opacity: 0.4; }
    50% { transform: translateY(-35px) rotate(3deg); opacity: 0.6; }
  }
  @keyframes float-4 {
    0%, 100% { transform: translateY(0) rotate(2deg); opacity: 0.5; }
    50% { transform: translateY(-20px) rotate(-3deg); opacity: 0.7; }
  }
  @keyframes float-5 {
    0%, 100% { transform: translateY(0) rotate(-4deg); opacity: 0.35; }
    50% { transform: translateY(-40px) rotate(1deg); opacity: 0.55; }
  }

  /* AI scanning line across contract docs */
  @keyframes scan-line {
    0% { top: 10%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 85%; opacity: 0; }
  }
  .animate-scan {
    animation: scan-line 4s ease-in-out infinite;
    position: absolute;
  }
  .animate-scan-delayed {
    animation: scan-line 4s ease-in-out infinite 2s;
    position: absolute;
  }

  /* Floating clause tags */
  .clause-tag {
    position: absolute;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
    font-family: 'Inter', monospace;
    letter-spacing: 0.02em;
    border: 1px solid rgba(124, 58, 237, 0.15);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
    color: rgba(167, 139, 250, 0.5);
    white-space: nowrap;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .tag-1 { top: 25%; right: 15%; animation: float-tag 14s infinite; color: rgba(167, 139, 250, 0.45); }
  .tag-2 { top: 65%; left: 8%; animation: float-tag 18s infinite 2s; color: rgba(251, 146, 60, 0.4); border-color: rgba(251, 146, 60, 0.12); }
  .tag-3 { bottom: 30%; right: 5%; animation: float-tag 16s infinite 4s; color: rgba(167, 139, 250, 0.4); }
  .tag-4 { top: 40%; right: 3%; animation: float-tag 20s infinite 1s; color: rgba(251, 146, 60, 0.35); border-color: rgba(251, 146, 60, 0.1); }
  .tag-5 { bottom: 15%; left: 20%; animation: float-tag 15s infinite 3s; color: rgba(167, 139, 250, 0.35); }
  .tag-6 { top: 10%; left: 30%; animation: float-tag 19s infinite 5s; color: rgba(251, 146, 60, 0.3); border-color: rgba(251, 146, 60, 0.08); }

  @keyframes float-tag {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.5; }
    25% { transform: translateY(-12px) translateX(8px); opacity: 0.7; }
    50% { transform: translateY(-6px) translateX(-5px); opacity: 0.6; }
    75% { transform: translateY(-18px) translateX(3px); opacity: 0.8; }
  }

  /* Background drift animations */
  @keyframes drift-slow {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(30px, -20px); }
    66% { transform: translate(-20px, 15px); }
  }
  @keyframes drift-med {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(-25px, 15px); }
    66% { transform: translate(15px, -25px); }
  }
  .animate-drift-slow { animation: drift-slow 30s ease-in-out infinite; }
  .animate-drift-med { animation: drift-med 20s ease-in-out infinite; }

  /* Feature ticker */
  .ticker-wrap {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .ticker {
    display: inline-flex;
    animation: ticker-scroll 30s linear infinite;
    white-space: nowrap;
  }
  .ticker-item {
    display: inline-block;
    padding: 0 24px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Override body for full dark */
  body { background: #030712; }
</style>

</BaseLayout>
