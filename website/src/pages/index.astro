---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const capabilities = [
  { n: '01', t: 'Contract Intelligence',    d: 'Parties, dates, values, 36 clause types extracted with paragraph-level citation.', href: '/features/contract-intelligence' },
  { n: '02', t: 'Obligation Tracking',      d: '7 obligation types, RAG status, owner assignment, audit-grade evidence.',         href: '/features/obligation-tracking' },
  { n: '03', t: 'SLA Monitoring',           d: '13 metric types, breach detection from ticketing, service-credit calculation.',    href: '/features/sla-monitoring' },
  { n: '04', t: 'Renewal Management',       d: 'Auto-renewal traps, notice-period windows surfaced 60–120 days early.',           href: '/features/renewal-management' },
  { n: '05', t: 'Relationship Governance',  d: 'KPI perception gaps, composite health scoring — only in Evaluetor.',              href: '/features/relationship-governance' },
];

const audiences = [
  { who: 'Legal',         outcome: 'Risk patterns across the portfolio, cited to source paragraph.' },
  { who: 'Procurement',   outcome: 'Credits, rebates, and renewal leverage — claimed, not lost.' },
  { who: 'Operations',    outcome: 'Every commitment with an owner and a deadline.' },
  { who: 'Finance',       outcome: 'One composite health number per contract, monthly.' },
  { who: 'Sales / AM',    outcome: 'Sell-side execution: own templates, own SLAs, own renewals.' },
];
---

<MarketingLayout
  title="AI-native CLM, built in the Netherlands"
  description="Evaluetor catches the contract value that leaks after signature — obligations, SLAs, risk, renewals, and relationships, in one platform."
>

<!-- ════════════════════════════════════════════════════════════ -->
<!-- HERO                                                          -->
<!-- ════════════════════════════════════════════════════════════ -->
<section class="section" style="padding-top: clamp(64px, 7vw, 120px); padding-bottom: clamp(40px, 4vw, 80px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">AI-native CLM &nbsp;·&nbsp; the Netherlands</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          Contracts <span class="emph">create value.</span><br/>
          Execution <span class="emph">protects it.</span><br/>
          Evaluetor handles execution.
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Organisations lose 8–11% of contract value after signing. The legacy CLM tools store and route documents. Evaluetor reads them, watches them perform, and surfaces the value that leaks during execution — obligations, SLAs, risk, renewals, and relationships, in one platform.
        </p>

        <div style="margin-top: 36px; display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
          <a href="/contact" class="cta-btn">Book a 30-min review <span class="arr">→</span></a>
          <a href="/commercial" class="cta-link">Read the long story →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════ -->
<!-- TRUST STRIP                                                   -->
<!-- ════════════════════════════════════════════════════════════ -->
<section style="border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--paper-2);">
  <div class="wrap" style="padding-top: 18px; padding-bottom: 18px;">
    <div class="grid grid-cols-2 md:grid-cols-4" style="gap: 18px;">
      <div>
        <div class="label">Built for</div>
        <p class="ink" style="font-size: 14px; margin-top: 4px; font-weight: 500;">EU mid-large enterprise</p>
      </div>
      <div>
        <div class="label">Engagement</div>
        <p class="ink" style="font-size: 14px; margin-top: 4px; font-weight: 500;">Portfolio, not per-seat</p>
      </div>
      <div>
        <div class="label">Time to first finding</div>
        <p class="ink" style="font-size: 14px; margin-top: 4px; font-weight: 500;">Inside a 30-min review</p>
      </div>
      <div>
        <div class="label">Residency</div>
        <p class="ink" style="font-size: 14px; margin-top: 4px; font-weight: 500;">EU regions available</p>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════ -->
<!-- CAPABILITIES                                                  -->
<!-- ════════════════════════════════════════════════════════════ -->
<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What's in the box</div>
      <h2 class="sechead-h display display-lg">Five disciplines. <span class="emph">One platform.</span></h2>
    </header>

    <div style="margin-top: 32px;">
      {capabilities.map((c) => (
        <a href={c.href} class="cap-row" style="text-decoration: none; transition: background .15s ease;">
          <span class="cap-num">{c.n}</span>
          <div>
            <div class="cap-t">{c.t} <span class="ink-3" style="font-size: 11px; font-family: 'Geist Mono', monospace; letter-spacing: 0.06em;">→</span></div>
            <p class="cap-d">{c.d}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════ -->
<!-- AUDIENCES                                                     -->
<!-- ════════════════════════════════════════════════════════════ -->
<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / Who uses it</div>
      <h2 class="sechead-h display display-lg">Five teams, <span class="emph">five views.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-5" style="gap: 1px; margin-top: 32px; background: var(--rule-2);">
      {audiences.map((a) => (
        <div style="background: var(--surface); padding: 22px 18px;">
          <div class="display display-md" style="color: var(--orange);">{a.who}</div>
          <p class="ink-2" style="font-size: 13.5px; line-height: 1.5; margin-top: 12px;">{a.outcome}</p>
        </div>
      ))}
    </div>

    <p style="margin-top: 28px;">
      <a href="/who-its-for" class="a-orange">See the five views in detail <span class="arr">→</span></a>
    </p>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════ -->
<!-- WHY EVALUETOR                                                 -->
<!-- ════════════════════════════════════════════════════════════ -->
<section class="section sr" style="background: var(--ink); color: var(--paper);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label" style="color: var(--orange);">03 / Why Evaluetor</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg" style="color: var(--paper);">
          AI-first, not AI-bolted-on.
        </h2>
        <p class="lead" style="margin-top: 22px; color: rgba(247,246,243,0.78); max-width: 680px;">
          Legacy CLM tools were built in the document-management era and bolted AI on later. Evaluetor was built model-first. Obligations, SLAs, risk, renewals, and relationship governance ship in the box — not as add-ons, not as roadmap items, not as professional-services engagements.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 28px; margin-top: 40px;">
          <div>
            <div class="display display-md" style="color: var(--orange);">9 agents</div>
            <p style="font-size: 14px; color: rgba(247,246,243,0.72); margin-top: 8px; line-height: 1.55;">Specialised AI agents in concert: extraction, Q&amp;A, risk, obligation, clause, renewal, SLA, schema, intent routing.</p>
          </div>
          <div>
            <div class="display display-md" style="color: var(--orange);">10 risk patterns</div>
            <p style="font-size: 14px; color: rgba(247,246,243,0.72); margin-top: 8px; line-height: 1.55;">Uncapped liability, broad indemnification, weak termination, auto-renewal traps, unfavourable IP, weak confidentiality, missing caps, one-sided terms, regulatory exposure, ambiguous language.</p>
          </div>
          <div>
            <div class="display display-md" style="color: var(--orange);">1 score</div>
            <p style="font-size: 14px; color: rgba(247,246,243,0.72); margin-top: 8px; line-height: 1.55;">Composite contract health — Risk &middot; SLA &middot; Obligations rolled up. The number the board reads.</p>
          </div>
        </div>

        <p style="margin-top: 36px;">
          <a href="/commercial" class="a-orange" style="color: var(--paper); border-bottom-color: var(--orange);">
            Read the full Why-Evaluetor story <span class="arr">→</span>
          </a>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════════════════ -->
<!-- CTA                                                           -->
<!-- ════════════════════════════════════════════════════════════ -->
<section class="section sr">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 gap-y-8 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">Begin</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">
          Bring five contracts.<br/>
          We will show you, <span class="emph">in thirty minutes,</span><br/>
          what your current CLM is missing.
        </h2>
        <div style="margin-top: 28px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/engage" class="cta-link" style="margin-left: 12px;">How we engage →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
