---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FeatureShowcase from '../components/FeatureShowcase.astro';
import StatsBar from '../components/StatsBar.astro';
import CTABanner from '../components/CTABanner.astro';
---

<MarketingLayout title="Customers - Trusted by Forward-Thinking Teams" description="See how legal, procurement, and operations teams use Evaluetor to transform contract management, recover service credits, and strengthen vendor relationships.">

  <!-- Hero -->
  <Hero
    tag="Customers"
    headline='Built for teams who are <span class="text-primary-600">done with the status quo</span>'
    subheadline="Legal, procurement, and ops teams use Evaluetor to turn contracts from filing cabinets into competitive advantages."
    primaryCTA={{ text: 'Join early access', href: '/contact' }}
    secondaryCTA={{ text: 'See Pricing', href: '/pricing' }}
  />

  <!-- Stats -->
  <StatsBar stats={[
    { value: '500+', label: 'Contracts Managed' },
    { value: '85%', label: 'Faster Reviews' },
    { value: '$2M+', label: 'Credits Recovered' },
    { value: '3x', label: 'Better Compliance' },
  ]} />

  <!-- Use Cases -->
  <section class="section-padding">
    <div class="container-narrow">
      <SectionHeading
        tag="Use Cases"
        title="Who it's for"
        subtitle="Three teams. One platform."
      />
      <div class="space-y-20 mt-12">
        <FeatureShowcase
          title="Legal Teams"
          description="Reduce contract review time from days to minutes. Evaluetor reads every clause, flags risks automatically, classifies obligations, and lets your legal team focus on strategy instead of document review."
          imagePosition="right"
          tag="Legal Operations"
          image="/screenshots/contract-qa.png"
          imageAlt="Contract Q&A for legal team review"
          bullets={[
            'Automated risk scoring across 10 risk categories',
            'Clause classification for 30+ clause types',
            'Compliance tracking with real-time status updates',
            'Portfolio-wide semantic search across all contracts',
          ]}
        />
        <FeatureShowcase
          title="Procurement Teams"
          description="Monitor vendor SLA performance in real time, detect breaches the moment they happen, and recover every service credit you are entitled to. Turn procurement from a cost center into a strategic function."
          imagePosition="left"
          tag="Strategic Procurement"
          image="/screenshots/sla-breaches.png"
          imageAlt="SLA breach monitoring for procurement teams"
          bullets={[
            'SLA breach detection with automatic severity classification',
            'Service credit calculation and recovery tracking',
            'Vendor performance scoring based on actual delivery',
            'Renewal optimization with AI-powered recommendations',
          ]}
        />
        <FeatureShowcase
          title="Finance & Operations"
          description="Track every contractual obligation and deadline across your entire portfolio. Avoid penalties from missed deadlines, detect auto-renewal traps, and understand the true financial exposure of your vendor agreements."
          imagePosition="right"
          tag="Financial Governance"
          image="/screenshots/compliance-reports.png"
          imageAlt="Compliance reporting for finance and operations"
          bullets={[
            'Obligation deadline tracking with automated alerts',
            'Penalty avoidance through proactive breach monitoring',
            'Auto-renewal detection and notice period calculation',
            'Budget impact analysis across the contract portfolio',
          ]}
        />
      </div>
    </div>
  </section>

  <!-- Early Results -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <SectionHeading
        tag="Early Results"
        title="What we're seeing so far"
        subtitle="We're early, but the results speak for themselves."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
        <div class="bg-white rounded-2xl p-8 border border-gray-200/60 text-center">
          <div class="text-3xl font-bold text-primary-700 mb-2">85%</div>
          <p class="text-sm text-gray-600">faster contract review compared to manual process</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-gray-200/60 text-center">
          <div class="text-3xl font-bold text-primary-700 mb-2">100%</div>
          <p class="text-sm text-gray-600">of obligations extracted and tracked automatically</p>
        </div>
        <div class="bg-white rounded-2xl p-8 border border-gray-200/60 text-center">
          <div class="text-3xl font-bold text-primary-700 mb-2">Minutes</div>
          <p class="text-sm text-gray-600">from upload to full intelligence — not weeks</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ROI Calculator -->
  <section class="section-padding">
    <div class="container-narrow">
      <SectionHeading
        tag="ROI"
        title="The ROI of contract intelligence"
        subtitle="Evaluetor customers see measurable results within the first weeks, not months. Here is what typical outcomes look like."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
        <div class="bg-white rounded-xl p-8 border border-gray-100 text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <div class="text-3xl font-bold text-primary-700 mb-2">90%</div>
          <h3 class="text-sm font-semibold text-gray-900 mb-1">Time Saved</h3>
          <p class="text-xs text-gray-500">Reduction in manual contract review time</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-gray-100 text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
          </div>
          <div class="text-3xl font-bold text-primary-700 mb-2">3-5x</div>
          <h3 class="text-sm font-semibold text-gray-900 mb-1">Credits Recovered</h3>
          <p class="text-xs text-gray-500">More SLA credits claimed than manual tracking</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-gray-100 text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          </div>
          <div class="text-3xl font-bold text-primary-700 mb-2">95%</div>
          <h3 class="text-sm font-semibold text-gray-900 mb-1">Fewer Missed Deadlines</h3>
          <p class="text-xs text-gray-500">Reduction in missed obligations and renewals</p>
        </div>
        <div class="bg-white rounded-xl p-8 border border-gray-100 text-center">
          <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" /></svg>
          </div>
          <div class="text-3xl font-bold text-primary-700 mb-2">Hours</div>
          <h3 class="text-sm font-semibold text-gray-900 mb-1">Implementation Time</h3>
          <p class="text-xs text-gray-500">Time to value, not months of setup</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    headline="Ready to stop managing contracts the old way?"
    subtext="Get early access and see the difference for yourself."
    buttonText="Get early access"
    buttonLink="/contact"
  />

</MarketingLayout>
