---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const capabilities = [
  {
    n: '01', t: 'Contract Intelligence',
    href: '/features/contract-intelligence',
    bullets: ['Parties, dates, values', '36 clause types extracted', '15 schemas, 1,235 fields', 'Paragraph-level citation'],
    closer: 'Read every contract. Cite every flag.',
  },
  {
    n: '02', t: 'Obligation Tracking',
    href: '/features/obligation-tracking',
    bullets: ['7 obligation types', 'Severity scoring', 'RAG portfolio dashboard', 'Owner assignment + audit log'],
    closer: 'Every commitment, with an owner.',
  },
  {
    n: '03', t: 'SLA Monitoring',
    href: '/features/sla-monitoring',
    bullets: ['13 metric types', 'Breach detection from ticketing', 'Service-credit calculation', 'A–F vendor scorecards'],
    closer: 'Credits claimed, not lost.',
  },
  {
    n: '04', t: 'Renewal Management',
    href: '/features/renewal-management',
    bullets: ['Auto-renewal trap detection', 'Notice-period windows', '60–120 day early surface', 'Side-by-side renegotiation prep'],
    closer: 'No surprise renewals.',
  },
  {
    n: '05', t: 'Relationship Governance',
    href: '/features/relationship-governance',
    bullets: ['KPI perception-gap scoring', 'Dual-side surveys', 'Composite health: Risk · SLA · Obligations', 'Improvement points with owners'],
    closer: 'The only platform measuring the relationship.',
  },
  {
    n: '06', t: 'Enterprise Security',
    href: '/platform',
    bullets: ['Multi-tenant isolation', 'EU residency available', 'Langfuse trace per AI call', 'Standard exit, no lock-in'],
    closer: 'Defensible from day one.',
  },
];

const compare = {
  cols: ['Evaluetor', 'DocuSign CLM', 'Icertis', 'Ironclad'],
  rows: [
    ['Time to first outcome',           ['Within weeks',  '6–12 months', '12–18 months', '3–6 months']],
    ['Native AI agents',                ['9',             'Limited add-on', 'Limited',    'Limited add-on']],
    ['Built-in SLA monitoring',         ['Yes',           'No',           'No',           'No']],
    ['AI-extracted obligations',        ['Yes — 7 types', 'Manual',       'Limited',      'Manual']],
    ['Relationship governance',         ['Yes — built-in', '—',           '—',            '—']],
    ['Composite contract health score', ['Yes',           '—',            '—',            '—']],
    ['User licensing',                  ['Unlimited',     'Per seat',     'Per seat',     'Per seat']],
    ['LLM observability (traceable)',   ['Yes — Langfuse', '—',            '—',            '—']],
  ],
};
---

<MarketingLayout
  title="Product overview"
  description="Six capabilities, one platform. Contract intelligence, obligation tracking, SLA monitoring, renewal management, relationship governance, enterprise security."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Product</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          Six capabilities.<br/>
          <span class="emph">None of them an add-on.</span><br/>
          None sold separately.
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Every legacy CLM tool sells the post-signature value as a roadmap item or a separate SKU. Evaluetor ships it in the box. Six capabilities cover the full execution surface — and they share one underlying data model.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What's in the box</div>
      <h2 class="sechead-h display display-lg">Six capabilities, <span class="emph">one platform.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3" style="gap: 1px; margin-top: 32px; background: var(--rule-2);">
      {capabilities.map((c) => (
        <a href={c.href} style="background: var(--surface); padding: 26px 22px; text-decoration: none; transition: background .15s ease; display: block;">
          <div class="label label-orange">{c.n}</div>
          <div class="display display-md" style="margin-top: 10px; margin-bottom: 14px;">{c.t}</div>
          <ul style="list-style: none; padding: 0; margin: 0;">
            {c.bullets.map((b) => (
              <li class="ink-2" style="font-size: 13.5px; padding: 5px 0; line-height: 1.45;">{b}</li>
            ))}
          </ul>
          <p class="emph ink-2" style="font-size: 17px; margin-top: 16px;">{c.closer}</p>
          <p style="margin-top: 14px;">
            <span class="a-orange" style="font-size: 13px;">Read more <span class="arr">→</span></span>
          </p>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / Versus the legacy stack</div>
      <h2 class="sechead-h display display-lg">Where the others <span class="emph">do not go.</span></h2>
    </header>

    <div style="margin-top: 28px; overflow-x: auto;">
      <table class="ctable">
        <thead>
          <tr>
            <th></th>
            {compare.cols.map((c, i) => (
              <th class={i === 0 ? 'us' : ''}>{c}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {compare.rows.map(([label, vals]) => (
            <tr>
              <td>{label}</td>
              {(vals as string[]).map((v, i) => (
                <td class={i === 0 ? 'us' : 'them'}>{v}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="mono ink-3" style="font-size: 11px; line-height: 1.6; margin-top: 16px; max-width: 760px;">
      Comparison reflects publicly documented capabilities of each platform at time of writing. Vendor pricing and packaging vary by region and customer size; figures in the "time to first outcome" row refer to median customer reports.
    </p>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">Begin</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Bring five contracts. <span class="emph">See it work.</span></h2>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/commercial" class="cta-link" style="margin-left: 12px;">Read the long story →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
