---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<MarketingLayout title="Contact Us - Book a Demo" description="Book a personalized demo or get in touch. See how Evaluetor can transform your contract management in a live session with your own documents.">

  <!-- Hero -->
  <Hero
    tag="Say hi"
    headline='Let&apos;s <span class="text-primary-600">talk contracts</span>'
    subheadline="Tell us what you're dealing with. We'll show you how Evaluetor can help — live, with your own documents."
    primaryCTA={{ text: 'Jump to form', href: '#contact-form' }}
    secondaryCTA={{ text: 'See the product first', href: '/product' }}
  />

  <!-- Contact Section -->
  <section class="section-padding" id="contact-form">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Left: Contact Form -->
        <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
          <ContactForm heading="Get in touch" />
        </div>

        <!-- Right: Company Info -->
        <div class="space-y-6">

          <!-- Office -->
          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 7.5h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-gray-900">Office</h3>
                <p class="mt-1 text-sm text-gray-600">Senority B.V.</p>
                <p class="text-sm text-gray-600">Rotterdam, The Netherlands</p>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-gray-900">Email</h3>
                <a href="mailto:sales@evaluetor.com" class="mt-1 text-sm text-primary-600 hover:text-primary-700 transition-colors">
                  sales@evaluetor.com
                </a>
              </div>
            </div>
          </div>

          <!-- What to Expect -->
          <div class="bg-white rounded-2xl border border-gray-100 p-6">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
              </div>
              <div>
                <h3 class="text-base font-semibold text-gray-900">What to Expect</h3>
                <ul class="mt-2 space-y-2">
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                    A real conversation, not a sales pitch
                  </li>
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                    Live demo with your actual contracts
                  </li>
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                    Honest pricing discussion
                  </li>
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                    Zero commitment, zero pressure
                  </li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</MarketingLayout>
