---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const principles = [
  ['AI-first, not AI-added',
   'Every competitor bolted AI onto a document repository. We built model-first. Nine specialised agents work in concert — extraction, risk, obligations, clauses, renewals, SLAs, Q&A, schema, intent routing.'],
  ['Relationships, not just documents',
   'Contracts define terms. Relationships determine outcomes. Evaluetor is the only platform that measures how both sides of a relationship perceive the partnership — the perception gap, scored continuously.'],
  ['European, audit-ready',
   'Built in the Netherlands. Multi-tenant isolation by design. EU residency available. Langfuse trace per AI call — every reasoning chain is inspectable, exportable, replayable.'],
];

const facts = [
  { v: '2024',                  k: 'Founded',     s: 'In the Netherlands' },
  { v: 'Evaluetor B.V.',         k: 'Entity',      s: 'Dutch private limited company' },
  { v: 'Post-signature CLM',     k: 'Focus',       s: 'Execution, not document routing' },
  { v: 'Self-funded',            k: 'Backed by',   s: 'Independent. Customer-focused.' },
];
---

<MarketingLayout
  title="About Evaluetor"
  description="A small team in the Netherlands building the contract intelligence platform that enterprises deserve but have never had."
>

<!-- HERO -->
<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">About</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          A small team <span class="emph">in the Netherlands.</span><br/>
          A big bet on <span class="emph">post-signature.</span>
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Enterprises spend millions negotiating contracts, then file them in a drawer. Nobody reads them. Nobody tracks the obligations. Nobody claims the service credits. When something goes wrong, everyone scrambles to find the document. We think that is fixable.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- THE BET -->
<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / The bet</div>
      <h2 class="sechead-h display display-lg">Contracts are <span class="emph">broken after signature.</span></h2>
    </header>

    <div class="grid grid-cols-12 gap-x-6" style="margin-top: 36px;">
      <div class="col-span-12 md:col-span-9 md:col-start-4">
        <p class="ink-2" style="font-size: 17px; line-height: 1.65; max-width: 680px;">
          Years in vendor governance and business-relationship management surfaced the same painful pattern across enterprise after enterprise: legal teams drowning in manual review, procurement missing SLA breaches, finance discovering auto-renewals after they triggered, no single owner for the value that was supposed to land.
        </p>
        <p class="ink-2" style="font-size: 17px; line-height: 1.65; margin-top: 16px; max-width: 680px;">
          Evaluetor was started in the Netherlands with a simple thesis: if AI can read and understand contracts better than any individual person, why are we still doing it manually? So we built a platform that does not just store contracts — it understands them, watches them perform, and surfaces what is leaking.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- PRINCIPLES -->
<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / How we are different</div>
      <h2 class="sechead-h display display-lg">Three things <span class="emph">we will not compromise on.</span></h2>
    </header>

    <div style="margin-top: 32px;">
      {principles.map(([title, desc], i) => (
        <div class="grid grid-cols-12 gap-x-6" style={`padding: 32px 0; ${i < principles.length - 1 ? 'border-bottom: 1px solid var(--rule-2);' : ''}`}>
          <div class="col-span-12 md:col-span-3">
            <div class="numeral-huge">{String(i+1).padStart(2,'0')}</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h3 class="display display-md">{title}</h3>
            <p class="ink-2" style="font-size: 15px; line-height: 1.65; margin-top: 12px; max-width: 620px;">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- COMPANY FACTS -->
<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">03 / Company facts</div>
      <h2 class="sechead-h display display-lg">The basics.</h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-4" style="gap: 1px; margin-top: 32px; background: var(--rule-2);">
      {facts.map((f) => (
        <div style="background: var(--paper); padding: 24px 20px;">
          <div class="display display-md">{f.v}</div>
          <div class="label" style="margin-top: 10px;">{f.k}</div>
          <p class="ink-3" style="font-size: 12px; margin-top: 4px;">{f.s}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section sr">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 gap-y-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">Meet the team</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Want to see <span class="emph">what we are building?</span></h2>
        <p class="lead" style="margin-top: 18px; max-width: 540px;">
          A real conversation, not a sales pitch. Live walkthrough with your own contracts. No slides.
        </p>
        <div style="margin-top: 28px;">
          <a href="/contact" class="cta-btn">Talk to the team <span class="arr">→</span></a>
          <a href="/product" class="cta-link" style="margin-left: 12px;">See the product →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
