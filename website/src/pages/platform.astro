---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const pipeline = [
  { n: '01', t: 'Ingest',     d: 'PDF and DOCX accepted. Parsed, chunked, embedded into a vector store (ChromaDB).' },
  { n: '02', t: 'Extract',    d: 'Nine specialised agents read each contract: metadata, clauses, obligations, risks, SLAs, renewals, schema.' },
  { n: '03', t: 'Score',      d: 'Risk patterns, obligation severity, SLA targets, composite health — calculated and stored per contract.' },
  { n: '04', t: 'Watch',      d: 'Continuous monitoring against external feeds — ITSM tickets, ERP volumes, FX rates, calendar windows.' },
  { n: '05', t: 'Surface',    d: 'Dashboards by team. Alerts by deadline. Improvement points with owner and priority.' },
  { n: '06', t: 'Act',        d: 'Findings turn into work. Credits claimed. Renewals negotiated. Risk re-papered. Loop closes.' },
];

const security = [
  { t: 'Multi-tenant isolation',  d: 'Every query is filtered by tenant at the data layer. Role-based access enforced at the API layer. Audit trail written for every action.' },
  { t: 'EU residency',             d: 'Production deployments can be pinned to EU regions. The public demo runs in a US region.' },
  { t: 'Langfuse observability',   d: 'Every AI call writes a trace — reasoning chain, prompts, model output. Inspectable, exportable, replayable. Defensible for risk teams.' },
  { t: 'Human-in-the-loop',        d: 'For the first thirty days on every new portfolio, every extraction is reviewed by an operator before becoming canonical.' },
  { t: 'No proprietary lock-in',   d: 'Contracts, extracted data, and audit trails export at any time as PDF, DOCX, or structured JSON. Standard exit terms allow notice without penalty.' },
  { t: 'Certifications',           d: 'SOC 2 Type II and ISO 27001 are on the roadmap. Architecture documentation available under NDA.' },
];

const stack = [
  { layer: 'API',                tech: 'Python 3.11 / FastAPI (async)' },
  { layer: 'Frontend',           tech: 'React / TypeScript / Vite' },
  { layer: 'Database',           tech: 'PostgreSQL + ChromaDB (vectors)' },
  { layer: 'AI orchestration',   tech: 'OpenAI GPT-4o + Agent Squad' },
  { layer: 'Observability',      tech: 'Langfuse via OpenTelemetry' },
  { layer: 'Deployment',         tech: 'Docker Compose — local + AWS EC2' },
];
---

<MarketingLayout
  title="Platform & architecture"
  description="AI-native architecture: nine specialised agents, multi-tenant by design, Langfuse traced, EU-residency-ready."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Platform</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          AI-first. <span class="emph">Audit-ready.</span><br/>
          Built for the long haul.
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Evaluetor is not a document repository with AI bolted on. Nine specialised agents read every contract, watch every commitment, and surface the work that protects the value the signature created.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / How it works</div>
      <h2 class="sechead-h display display-lg">Six steps, <span class="emph">in order.</span></h2>
    </header>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6" style="gap: 1px; margin-top: 32px; background: var(--rule-2);">
      {pipeline.map((p) => (
        <div style="background: var(--surface); padding: 20px 16px;">
          <div class="mono ink-3" style="font-size: 10px; letter-spacing: 0.14em;">{p.n}</div>
          <div class="ink" style="font-size: 15px; font-weight: 500; margin-top: 8px; letter-spacing: -0.01em;">{p.t}</div>
          <p class="ink-3" style="font-size: 12.5px; line-height: 1.5; margin-top: 8px;">{p.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / Security &amp; governance</div>
      <h2 class="sechead-h display display-lg">Defensible <span class="emph">from day one.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0" style="margin-top: 28px;">
      {security.map(({t, d}, i) => (
        <div style={`padding: 22px 0; border-bottom: 1px solid var(--rule-2); ${i < 2 ? 'border-top: 1px solid var(--rule-2);' : ''}`}>
          <div class="display display-sm" style="margin-bottom: 8px;">{t}</div>
          <p class="ink-3" style="font-size: 14px; line-height: 1.6;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">03 / Technical stack</div>
      <h2 class="sechead-h display display-lg">What is under the hood.</h2>
    </header>

    <div class="grid grid-cols-12 gap-x-6 gap-y-8" style="margin-top: 32px;">
      <div class="col-span-12 md:col-span-7">
        <table class="ctable">
          <thead>
            <tr><th>Layer</th><th>Technology</th></tr>
          </thead>
          <tbody>
            {stack.map((s) => (
              <tr><td>{s.layer}</td><td class="mono ink-3" style="font-size: 13px;">{s.tech}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="col-span-12 md:col-span-5">
        <div style="border: 1px solid var(--rule-2); background: var(--surface); padding: 24px;">
          <div class="label label-orange" style="margin-bottom: 14px;">Scale today</div>
          <ul style="list-style: none; padding: 0; margin: 0;">
            <li class="ink-2" style="font-size: 14px; padding: 8px 0; border-bottom: 1px solid var(--rule-2);"><span class="mono ink-3" style="font-size: 11px; margin-right: 10px;">9</span>specialised AI agents</li>
            <li class="ink-2" style="font-size: 14px; padding: 8px 0; border-bottom: 1px solid var(--rule-2);"><span class="mono ink-3" style="font-size: 11px; margin-right: 10px;">36</span>clause types extracted</li>
            <li class="ink-2" style="font-size: 14px; padding: 8px 0; border-bottom: 1px solid var(--rule-2);"><span class="mono ink-3" style="font-size: 11px; margin-right: 10px;">10</span>risk patterns scored</li>
            <li class="ink-2" style="font-size: 14px; padding: 8px 0; border-bottom: 1px solid var(--rule-2);"><span class="mono ink-3" style="font-size: 11px; margin-right: 10px;">7</span>obligation types classified</li>
            <li class="ink-2" style="font-size: 14px; padding: 8px 0; border-bottom: 1px solid var(--rule-2);"><span class="mono ink-3" style="font-size: 11px; margin-right: 10px;">13</span>SLA metric types tracked</li>
            <li class="ink-2" style="font-size: 14px; padding: 8px 0;"><span class="mono ink-3" style="font-size: 11px; margin-right: 10px;">15</span>contract-type schemas with 1,235 fields</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">Review</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Want the architecture deck <span class="emph">under NDA?</span></h2>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Get in touch <span class="arr">→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
