  <!-- Slide Navigation Script -->
  <script is:inline>
    let currentSlide = 1;
    const totalSlides = 7;
    let isTransitioning = false;

    function goToSlide(n) {
      if (isTransitioning || n < 1 || n > totalSlides || n === currentSlide) return;
      isTransitioning = true;
      currentSlide = n;

      const deck = document.getElementById('deck');
      deck.style.transform = `translateY(-${(n - 1) * 100}vh)`;

      // Update progress bar
      document.getElementById('progress-bar').style.width = `${(n / totalSlides) * 100}%`;

      // Update counter
      document.getElementById('slide-counter').textContent = `${n} / ${totalSlides}`;

      setTimeout(() => { isTransitioning = false; }, 600);
    }

    function nextSlide() { goToSlide(currentSlide + 1); }
    function prevSlide() { goToSlide(currentSlide - 1); }

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight' || e.key === ' ') {
        e.preventDefault();
        nextSlide();
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault();
        prevSlide();
      } else if (e.key === 'Home') {
        e.preventDefault();
        goToSlide(1);
      } else if (e.key === 'End') {
        e.preventDefault();
        goToSlide(totalSlides);
      }
    });

    // Mouse wheel navigation
    let wheelTimeout;
    document.addEventListener('wheel', (e) => {
      e.preventDefault();
      clearTimeout(wheelTimeout);
      wheelTimeout = setTimeout(() => {
        if (e.deltaY > 0) nextSlide();
        else prevSlide();
      }, 50);
    }, { passive: false });

    // Touch navigation
    let touchStartY = 0;
    document.addEventListener('touchstart', (e) => {
      touchStartY = e.changedTouches[0].screenY;
    });
    document.addEventListener('touchend', (e) => {
      const diff = touchStartY - e.changedTouches[0].screenY;
      if (Math.abs(diff) > 50) {
        if (diff > 0) nextSlide();
        else prevSlide();
      }
    });

    // Fade out nav hint after a few seconds
    setTimeout(() => {
      const hint = document.getElementById('nav-hint');
      if (hint) hint.querySelector('span').style.opacity = '0';
    }, 5000);
  </script>

  <style is:global>
    body {
