---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const capabilities = [
  ['Auto-renewal detection',      'Every contract with an auto-renewal clause is identified and flagged. Notice-period windows are extracted to the day.'],
  ['Early surface — 60–120 days', 'Configurable lead-time alerts. Most renewals surface 60–120 days before the notice deadline, giving procurement time to renegotiate, not just react.'],
  ['Renewal calendar',            'Portfolio-wide calendar view of upcoming renewals, with value, vendor, notice deadline, and current health score.'],
  ['Renegotiation prep',           'Side-by-side comparison of current terms vs. portfolio norms vs. market benchmarks (where we have them). Surfaces the case for renegotiation.'],
  ['Both-sides view',              'For sell-side teams: same calendar, same prep, applied to customer renewals. Protect the book before churn lands on the AM\'s desk.'],
  ['Health-conditioned alerts',    'Renewals attached to vendors with red composite health scores get escalated automatically. Healthy renewals stay quiet.'],
];
---

<MarketingLayout
  title="Renewal Management"
  description="No surprise renewals. Auto-renewal trap detection, notice-period windows, 60-120 day early surface."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Capability &nbsp;·&nbsp; 04</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          No surprise <span class="emph">renewals.</span>
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Auto-renewal clauses are the most-quoted leakage source in any procurement war story. Evaluetor extracts them, calendars them, and surfaces them with enough lead time that you negotiate — instead of just paying.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What it does</div>
      <h2 class="sechead-h display display-lg">Six things, <span class="emph">before the deadline.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0" style="margin-top: 28px;">
      {capabilities.map(([t, d], i) => (
        <div style={`padding: 22px 0; border-bottom: 1px solid var(--rule-2); ${i < 2 ? 'border-top: 1px solid var(--rule-2);' : ''}`}>
          <div class="display display-sm" style="margin-bottom: 8px;">{t}</div>
          <p class="ink-3" style="font-size: 14px; line-height: 1.6;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">See it work</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Find out which auto-renewals <span class="emph">are about to trigger.</span></h2>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/features/relationship-governance" class="cta-link" style="margin-left: 12px;">Next: Relationship governance →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
