---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FeatureShowcase from '../../components/FeatureShowcase.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import StatsBar from '../../components/StatsBar.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<MarketingLayout title="SLA Monitoring - Real-Time Breach Detection & Penalty Tracking" description="Monitor 9 SLA metric types in real time with automatic breach detection, severity classification, penalty calculation, and service credit recovery tracking.">

  <!-- Hero -->
  <Hero
    tag="SLA Monitoring"
    headline='Detect breaches and <span class="text-primary-600">recover every credit</span> you are owed'
    subheadline="Extract SLA targets from contracts, monitor performance in real time, detect breaches instantly, and calculate every credit your vendors owe you."
    primaryCTA={{ text: 'Start recovering credits', href: '/contact' }}
    secondaryCTA={{ text: 'See Pricing', href: '/pricing' }}
  />

  <!-- Stats -->
  <StatsBar stats={[
    { value: '9', label: 'SLA metric types supported' },
    { value: '3-5x', label: 'More credits recovered' },
    { value: '4', label: 'Severity levels tracked' },
    { value: 'Real-time', label: 'Performance monitoring' },
  ]} />

  <!-- Showcase 1: SLA Extraction -->
  <section class="section-padding">
    <div class="container-narrow">
      <SectionHeading
        tag="Automated Extraction"
        title="SLA terms extracted straight from the contract"
        subtitle="Our SLA Extraction Agent reads your agreements and pulls out every metric, target, threshold, and penalty clause, so you always know exactly what was promised."
      />
      <FeatureShowcase
        title="SLA Extraction"
        description="No more manually building SLA tracking spreadsheets. Upload your contract and our AI identifies every service level commitment, including the targets, measurement methods, and financial consequences."
        imagePosition="right"
        tag="AI-Powered"
        image="/screenshots/sla-config.png"
        imageAlt="SLA configuration and metric extraction"
        bullets={[
          'Extracts 9 metric types: Uptime, Response Time, Resolution Time, Throughput, Error Rate, Availability, Latency, MTTR, and Custom',
          'Captures target values, minimum thresholds, and measurement periods',
          'Identifies penalty structures including per-incident fees, percentage-based credits, and tiered escalations',
          'Links each SLA to its source clause for audit traceability',
          'Detects service credit caps and maximum liability thresholds',
        ]}
      />
    </div>
  </section>

  <!-- Showcase 2: Breach Detection -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <FeatureShowcase
        title="Breach Detection & Classification"
        description="When a vendor misses their target, Evaluetor detects it immediately, classifies the severity, and tracks consecutive breach patterns that may trigger escalation clauses."
        imagePosition="left"
        tag="Proactive Alerts"
        image="/screenshots/sla-breaches.png"
        imageAlt="SLA breach detection with severity classification"
        bullets={[
          'Automatic breach detection when performance data falls below contracted thresholds',
          'Four severity levels: Minor, Moderate, Major, and Critical, based on deviation from targets',
          'Consecutive breach counting triggers escalation alerts when patterns emerge',
          'Historical trend analysis identifies degrading performance before formal breaches occur',
          'Configurable notification rules alert the right stakeholders based on severity and contract value',
        ]}
      />
    </div>
  </section>

  <!-- Showcase 3: Financial Impact -->
  <section class="section-padding">
    <div class="container-narrow">
      <FeatureShowcase
        title="Financial Impact & Credit Recovery"
        description="Every breach has a cost. Evaluetor calculates the exact penalties and service credits owed based on your contract terms, tracks credit recovery, and maintains a complete audit trail for vendor discussions."
        imagePosition="right"
        tag="Revenue Recovery"
        image="/screenshots/compliance-reports.png"
        imageAlt="Financial impact analysis and credit recovery tracking"
        bullets={[
          'Automated penalty calculation based on contract-specific formulas and rate cards',
          'Service credit tracking with running totals per vendor, per contract, and per period',
          'Credit cap monitoring ensures you claim up to the maximum allowed under the agreement',
          'Exportable breach and credit reports for vendor business reviews',
          'Complete financial audit trail documenting every calculation and its contractual basis',
        ]}
      />
    </div>
  </section>

  <!-- Additional Features -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <SectionHeading
        tag="More Capabilities"
        title="End-to-end SLA lifecycle management"
        subtitle="From contract extraction to credit recovery, Evaluetor covers every aspect of SLA management."
      />
      <FeatureGrid>
        <FeatureCard
          title="Performance Dashboards"
          description="Visual dashboards show SLA compliance across all vendors and contracts. Drill down from portfolio-level summaries to individual metric performance over time."
          icon='<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>'
        />
        <FeatureCard
          title="Vendor Scorecards"
          description="Aggregate SLA performance into vendor scorecards that combine compliance rates, breach frequency, and financial impact into a single health score for each provider."
          icon='<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>'
        />
        <FeatureCard
          title="Trend Analysis & Forecasting"
          description="Identify vendors with declining performance trends before they become critical. Predictive indicators highlight contracts at risk of future SLA breaches based on historical patterns."
          icon='<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" /></svg>'
        />
      </FeatureGrid>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    headline="Leaving money on the table?"
    subtext="Most teams are. Our AI finds every SLA breach and calculates what you're owed."
    buttonText="See it live"
    buttonLink="/contact"
  />

</MarketingLayout>
