---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const capabilities = [
  ['13 metric types',           'Uptime, response time, resolution time, throughput, error rate, accuracy, completeness, timeliness, recovery time, availability, performance, capacity, and custom metrics.'],
  ['Breach detection',           'Connect ServiceNow or your ticketing system. Actual incidents are compared to extracted SLA thresholds. Breaches flagged the day they happen, not at the next QBR.'],
  ['Service-credit calculation', 'Each breach is monetised against the credit table in the underlying contract. Calculation logic is inspectable and exportable.'],
  ['A–F vendor scorecards',      'Each vendor gets a grade rolled up from breach frequency, severity, and credit position. Comparable across the portfolio.'],
  ['Quarterly business review',  'Auto-generated QBR pack: breach history, credit position, comparable benchmarks, recommended renegotiation positions.'],
  ['Recovery workflow',          'Findings turn into work — credit claims drafted, escalation paths defined, dispute trail captured.'],
];
---

<MarketingLayout
  title="SLA Monitoring"
  description="Credits claimed, not lost. 13 metric types, breach detection from ticketing, A-F vendor scorecards."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Capability &nbsp;·&nbsp; 03</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          Credits claimed, <span class="emph">not lost.</span>
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Most enterprises let SLA credits expire because nobody reconciles ticket data against contract thresholds. Evaluetor closes that loop — extract the SLA, ingest the actuals, surface the breach, calculate the credit, route the claim.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What it does</div>
      <h2 class="sechead-h display display-lg">Six things, <span class="emph">continuously.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0" style="margin-top: 28px;">
      {capabilities.map(([t, d], i) => (
        <div style={`padding: 22px 0; border-bottom: 1px solid var(--rule-2); ${i < 2 ? 'border-top: 1px solid var(--rule-2);' : ''}`}>
          <div class="display display-sm" style="margin-bottom: 8px;">{t}</div>
          <p class="ink-3" style="font-size: 14px; line-height: 1.6;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">See it work</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Show us your <span class="emph">worst-performing vendor.</span></h2>
        <p class="lead" style="margin-top: 18px; max-width: 580px;">
          We will extract the SLAs, line them up against your last twelve months of tickets, and tell you what credit position you have left to claim.
        </p>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/features/renewal-management" class="cta-link" style="margin-left: 12px;">Next: Renewal management →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
