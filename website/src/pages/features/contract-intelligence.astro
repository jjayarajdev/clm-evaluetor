---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const capabilities = [
  ['Parties, dates, values',     'Names, signatories, jurisdiction, effective and termination dates, contract value, currency, payment terms — extracted from the document, not from a sidecar metadata form.'],
  ['36 clause types',             'Indemnity, liability, IP, termination, confidentiality, assignment, force majeure, governing law, dispute resolution, change of control, exclusivity, audit rights, and 24 more — each classified, scored, and cited.'],
  ['15 contract schemas',         '1,235 typed fields across MSA, SOW, NDA, employment, lease, SaaS, services, supply, distribution, licensing, M&A, JV, franchise, partnership, insurance.'],
  ['Paragraph-level citation',    'Every extracted fact and every risk flag points back to the exact paragraph in the source document. Legal counsel can verify a finding in seconds.'],
  ['Cross-portfolio anomaly',     'Find the one outlier indemnity clause across 200 SaaS contracts. Surface the supplier whose termination terms drift from your portfolio norm.'],
  ['Contract Q&A',                'Ask natural-language questions across the portfolio. Answers cite source. Built on the same vector index used by extraction.'],
];

const agents = [
  ['Metadata extraction',    'Parties, dates, values, jurisdiction'],
  ['Schema extraction',      '15 contract types · 1,235 typed fields'],
  ['Clause extraction',      '36 clause types · paragraph-citing'],
  ['Contract Q&A',            'RAG-powered answers across the portfolio'],
  ['Intent routing',         'Queries routed to the right agent or tool'],
];
---

<MarketingLayout
  title="Contract Intelligence"
  description="Read every contract. Score every clause. 36 clause types, 15 schemas, paragraph-level citation."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Capability &nbsp;·&nbsp; 01</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          Read every contract. <span class="emph">Cite every flag.</span>
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          The foundation underneath the rest of the platform. Five specialised agents parse, classify, and extract — into a structured model that the rest of Evaluetor can reason over.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What it does</div>
      <h2 class="sechead-h display display-lg">Six things, <span class="emph">at portfolio scale.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0" style="margin-top: 28px;">
      {capabilities.map(([t, d], i) => (
        <div style={`padding: 22px 0; border-bottom: 1px solid var(--rule-2); ${i < 2 ? 'border-top: 1px solid var(--rule-2);' : ''}`}>
          <div class="display display-sm" style="margin-bottom: 8px;">{t}</div>
          <p class="ink-3" style="font-size: 14px; line-height: 1.6;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / Under the hood</div>
      <h2 class="sechead-h display display-lg">Five agents <span class="emph">in concert.</span></h2>
    </header>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5" style="gap: 1px; margin-top: 28px; background: var(--rule-2);">
      {agents.map(([t, d], i) => (
        <div style="background: var(--surface); padding: 18px 16px;">
          <div class="mono ink-3" style="font-size: 10px; letter-spacing: 0.14em;">{String(i+1).padStart(2,'0')}</div>
          <div class="ink" style="font-size: 14px; font-weight: 500; margin-top: 8px; letter-spacing: -0.01em;">{t}</div>
          <p class="ink-3" style="font-size: 12.5px; line-height: 1.5; margin-top: 6px;">{d}</p>
        </div>
      ))}
    </div>

    <p class="ink-3" style="font-size: 13px; margin-top: 20px; max-width: 680px; line-height: 1.6;">
      Each agent's reasoning chain is written to a Langfuse trace — prompts, model output, citations — and can be replayed, exported, or audited.
    </p>
  </div>
</section>

<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">Try it</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Drop in five contracts. <span class="emph">See what it pulls.</span></h2>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/product" class="cta-link" style="margin-left: 12px;">All six capabilities →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
