---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FeatureShowcase from '../../components/FeatureShowcase.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import FeatureGrid from '../../components/FeatureGrid.astro';
import StatsBar from '../../components/StatsBar.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<MarketingLayout title="Relationship Governance - KPI Scoring, Perception Gaps & Surveys" description="Manage business relationships with multi-party KPI perception scoring, gap analysis, auto-generated improvement plans, and satisfaction surveys with external portal access.">

  <!-- Hero -->
  <Hero
    tag="Relationship Governance"
    headline='Manage the relationship, <span class="text-primary-600">not just the contract</span>'
    subheadline="Track vendor performance, surface perception gaps between you and your partners, and drive improvement with data — not gut feel."
    primaryCTA={{ text: 'See the difference', href: '/contact' }}
    secondaryCTA={{ text: 'See Pricing', href: '/pricing' }}
  />

  <!-- Stats -->
  <StatsBar stats={[
    { value: '360\u00B0', label: 'Relationship visibility' },
    { value: 'Multi-party', label: 'Satisfaction surveys' },
    { value: 'Auto', label: 'Generated improvements' },
    { value: 'Gap', label: 'Perception analysis' },
  ]} />

  <!-- Showcase 1: Vendor Performance Scoring -->
  <section class="section-padding">
    <div class="container-narrow">
      <SectionHeading
        tag="Performance Intelligence"
        title="Quantify every vendor relationship"
        subtitle="Move beyond subjective opinions. Evaluetor calculates vendor performance scores from real contract data, weighting the factors that matter most to your business."
      />
      <FeatureShowcase
        title="Vendor Performance Scoring"
        description="A multi-factor scoring model that combines contractual compliance data into a single, defensible vendor health score. Use it for business reviews, procurement decisions, and relationship escalations."
        imagePosition="right"
        tag="Data-Driven Scoring"
        image="/screenshots/counterparty-performance.png"
        imageAlt="Counterparty performance scoring dashboard"
        bullets={[
          'Obligation fulfillment weighted at 40% reflects whether the vendor delivers what was promised',
          'SLA compliance weighted at 30% measures service quality against contracted targets',
          'Responsiveness score weighted at 20% tracks communication and issue resolution speed',
          'Issue rate weighted at 10% captures frequency and severity of problems encountered',
          'Scores calculated automatically from platform data with full drill-down to source metrics',
        ]}
      />
    </div>
  </section>

  <!-- Showcase 2: KPI Perception Gaps -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <FeatureShowcase
        title="KPI Perception Gaps"
        description="The most dangerous risks in a business relationship are the ones nobody talks about. Perception gap analysis reveals where your team and your partner disagree on performance, before those disagreements become disputes."
        imagePosition="left"
        tag="Perception Intelligence"
        image="/screenshots/vendor-performance.png"
        imageAlt="KPI perception gap analysis between internal and external scores"
        bullets={[
          'Define KPIs per relationship and collect internal and external perception scores (1-10 scale)',
          'Automatic gap calculation with severity classification: Aligned, Minor Gap, Significant Gap, Critical Gap',
          'Auto-generated improvement points when perception gaps exceed configurable thresholds',
          'Historical gap trending shows whether relationships are improving or deteriorating over time',
          'Side-by-side visualization of internal versus external perception across all KPIs',
        ]}
      />
    </div>
  </section>

  <!-- Showcase 3: Satisfaction Surveys -->
  <section class="section-padding">
    <div class="container-narrow">
      <FeatureShowcase
        title="Satisfaction Surveys"
        description="Collect structured feedback from both internal stakeholders and external partners through a purpose-built survey system. Anonymous responses, tokenized access, and template management make it easy to run recurring satisfaction assessments."
        imagePosition="right"
        tag="Multi-Party Feedback"
        image="/screenshots/users.png"
        imageAlt="User management and survey distribution interface"
        bullets={[
          'Template management with reusable question sets for different relationship types',
          'External survey portal with tokenized access links that require no account or login',
          'Anonymous response option encourages honest feedback from all participants',
          'Automated survey distribution with configurable schedules and reminder cadences',
          'Response analytics with scoring breakdowns, trend comparisons, and exportable reports',
        ]}
      />
    </div>
  </section>

  <!-- Additional Features -->
  <section class="section-padding bg-gray-50">
    <div class="container-narrow">
      <SectionHeading
        tag="More Capabilities"
        title="Governance that strengthens every relationship"
        subtitle="From organization profiles to improvement tracking, Evaluetor provides the structure to manage business relationships systematically."
      />
      <FeatureGrid>
        <FeatureCard
          title="Organization Management"
          description="Maintain rich profiles for every customer, vendor, and partner. Track relationship types, team hierarchies, escalation paths, and governance structures in one central directory."
          icon='<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" /></svg>'
        />
        <FeatureCard
          title="Improvement Point Tracking"
          description="When perception gaps or performance issues surface, Evaluetor creates actionable improvement points with owners, deadlines, and status tracking. Close the loop from insight to action."
          icon='<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" /></svg>'
        />
        <FeatureCard
          title="Relationship Health Dashboard"
          description="A single executive view showing the health of every business relationship. Combine vendor scores, perception gaps, survey results, and improvement progress into one actionable dashboard."
          icon='<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>'
        />
      </FeatureGrid>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    headline="Ready to manage relationships, not just paperwork?"
    subtext="See how perception gap analysis reveals what your vendor scorecards miss."
    buttonText="Get a demo"
    buttonLink="/contact"
  />

</MarketingLayout>
