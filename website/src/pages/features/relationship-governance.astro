---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const capabilities = [
  ['Dual-perspective KPI scoring', 'Both sides of the relationship score the same KPIs against the same definitions. The delta between the two scores is the perception gap.'],
  ['Three input channels',         'Structured surveys (periodic), operational signals (SLA performance, obligation fulfilment, ticket data), and communication-cadence signals (where available). Composite gap score per KPI.'],
  ['Composite health score',       'Risk (30%) · SLA (40%) · Obligations (30%). One number per contract. Auditable. Defensible. Comparable.'],
  ['Improvement points',           'Where the gap exceeds a configurable threshold, an improvement point is auto-generated — with owner, priority, and due date. Closes the loop.'],
  ['Survey workflow',              'Schedule, distribute, collect, and score periodic surveys. Both sides can see their own scores and the agreed-upon delta.'],
  ['Industry profiles',            'Per-contract industry profile drives which KPIs apply. A telecoms vendor relationship is not scored on healthcare KPIs.'],
];

const formula = [
  ['Risk',         '30%', 'Contract risk patterns + clause severity'],
  ['SLA',          '40%', 'Service-level performance + breach history'],
  ['Obligations',  '30%', 'Commitment fulfilment + audit position'],
];
---

<MarketingLayout
  title="Relationship Governance"
  description="The discipline only Evaluetor ships. Perception-gap scoring, composite contract health, improvement points with owners."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Capability &nbsp;·&nbsp; 05</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          The discipline <span class="emph">only we ship.</span>
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          Contracts define terms. Relationships determine outcomes. Every legacy CLM ignores the second half. Evaluetor measures it — continuously, on both sides, with a defensible audit trail.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What it does</div>
      <h2 class="sechead-h display display-lg">Six things, <span class="emph">continuously.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0" style="margin-top: 28px;">
      {capabilities.map(([t, d], i) => (
        <div style={`padding: 22px 0; border-bottom: 1px solid var(--rule-2); ${i < 2 ? 'border-top: 1px solid var(--rule-2);' : ''}`}>
          <div class="display display-sm" style="margin-bottom: 8px;">{t}</div>
          <p class="ink-3" style="font-size: 14px; line-height: 1.6;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / The composite formula</div>
      <h2 class="sechead-h display display-lg">One number. <span class="emph">Three weighted parts.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 1px; margin-top: 32px; background: var(--rule-2);">
      {formula.map(([t, w, d]) => (
        <div style="background: var(--surface); padding: 28px 22px; border: 1px solid var(--rule-2);">
          <div class="numeral-huge" style="font-size: clamp(48px, 6vw, 80px);">{w}</div>
          <div class="display display-md" style="margin-top: 10px;">{t}</div>
          <p class="ink-3" style="font-size: 13.5px; line-height: 1.55; margin-top: 8px;">{d}</p>
        </div>
      ))}
    </div>

    <p class="ink-3 mono" style="font-size: 12px; margin-top: 18px; line-height: 1.6; max-width: 680px;">
      Weights are configurable per industry profile. The defaults are derived from research across vendor-governance literature and Evaluetor's pilot engagements; sectors with heavy regulatory exposure tend to weight Risk higher.
    </p>
  </div>
</section>

<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">See it work</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Pick one vendor relationship. <span class="emph">We will score it.</span></h2>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/commercial" class="cta-link" style="margin-left: 12px;">Read the long story →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
