---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const capabilities = [
  ['7 obligation types',          'Payment, delivery, reporting, compliance, notification, performance, other — each classified with severity and consequence.'],
  ['Owner assignment',            'Every obligation gets a named owner inside your organisation. No commitment floats without accountability.'],
  ['Deadline tracking',           'Configurable lead-time alerts: 90 days, 30 days, day-of, post-due. Trigger by email, in-app, or webhook to ticketing.'],
  ['RAG portfolio dashboard',     'Red, amber, green status across every obligation in scope. Drill from portfolio to contract to clause in two clicks.'],
  ['Evidence + audit log',        'Each obligation links to source paragraph, owner, status history, and the fulfilment evidence — defensible to internal audit and external counsel.'],
  ['Compliance reporting',        'Export obligation status by department, contract, vendor, or period. Standard formats auditors recognise.'],
];

const seven = [
  ['Payment',       'Invoice triggers, milestone payments, fees, penalties'],
  ['Delivery',      'Goods, services, deliverables, acceptance criteria'],
  ['Reporting',     'Periodic reports, status updates, KPI submissions'],
  ['Compliance',    'Certifications, audits, regulatory submissions'],
  ['Notification',  'Required notices to counterparty — change, breach, renewal'],
  ['Performance',   'Service-level commitments, capacity, availability'],
  ['Other',         'Catch-all for contract-specific commitments'],
];
---

<MarketingLayout
  title="Obligation Tracking"
  description="Every commitment, with an owner and a deadline. 7 obligation types, RAG status, configurable alerts, audit-grade evidence."
>

<section class="section" style="padding-top: clamp(56px, 6vw, 100px); padding-bottom: clamp(40px, 4vw, 64px);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-ink">Capability &nbsp;·&nbsp; 02</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h1 class="display display-xl" style="margin-top: 12px;">
          Every commitment, <span class="emph">with an owner.</span>
        </h1>
        <p class="lead" style="margin-top: 28px; max-width: 720px;">
          The contract said it. The team signed it. Nobody owns it. Evaluetor closes that gap — every extracted obligation gets a named owner, a deadline, and a defensible evidence trail.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--surface); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule);">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">01 / What it does</div>
      <h2 class="sechead-h display display-lg">Six things, <span class="emph">every day.</span></h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-0" style="margin-top: 28px;">
      {capabilities.map(([t, d], i) => (
        <div style={`padding: 22px 0; border-bottom: 1px solid var(--rule-2); ${i < 2 ? 'border-top: 1px solid var(--rule-2);' : ''}`}>
          <div class="display display-sm" style="margin-bottom: 8px;">{t}</div>
          <p class="ink-3" style="font-size: 14px; line-height: 1.6;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr">
  <div class="wrap">
    <header class="sechead">
      <div class="sechead-num label label-ink">02 / The seven types</div>
      <h2 class="sechead-h display display-lg">Classified, <span class="emph">not just extracted.</span></h2>
    </header>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4" style="gap: 1px; margin-top: 28px; background: var(--rule-2);">
      {seven.map(([t, d], i) => (
        <div style="background: var(--surface); padding: 20px 16px;">
          <div class="mono ink-3" style="font-size: 10px; letter-spacing: 0.14em;">{String(i+1).padStart(2,'0')}</div>
          <div class="ink" style="font-size: 15px; font-weight: 500; margin-top: 8px; letter-spacing: -0.01em;">{t}</div>
          <p class="ink-3" style="font-size: 12.5px; line-height: 1.5; margin-top: 8px;">{d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section sr" style="background: var(--paper-2);">
  <div class="wrap">
    <div class="grid grid-cols-12 gap-x-6 items-baseline">
      <div class="col-span-12 md:col-span-3">
        <div class="label label-orange">See it work</div>
      </div>
      <div class="col-span-12 md:col-span-9">
        <h2 class="display display-lg">Bring five contracts. <span class="emph">See every commitment.</span></h2>
        <div style="margin-top: 24px;">
          <a href="/contact" class="cta-btn">Book a review <span class="arr">→</span></a>
          <a href="/features/sla-monitoring" class="cta-link" style="margin-left: 12px;">Next: SLA monitoring →</a>
        </div>
      </div>
    </div>
  </div>
</section>

</MarketingLayout>
