  },
  {
    title: 'SLA', where: 'ServiceNow', systems: 'ITSM · ticketing',
    desc: 'Read incidents, response and resolution times. Detect breaches in real time.',
    sample: [['Target', '15m'], ['Actual', '23m'], ['Breached', '7 / 12'], ['Credit', '4.2% MRR']],
  },
  {
    title: 'FX', where: 'ECB', systems: 'European Central Bank',
    desc: 'Pull live FX rates for indexed contracts. Flag the moment thresholds break.',
    sample: [['Peg', '1.0850'], ['Today', '1.1024'], ['Δ', '+1.6%'], ['Status', 'Reprice']],
  },
];

const capabilities = [
  ['Contract Intelligence',   'Metadata · 30+ clause types · 10 risk categories · semantic search.', false],
  ['Obligation Tracking',     'RAG status · owner assignment · escalation · evidence of completion.', false],
  ['SLA Monitoring',          'Breach detection · automated credit math · A–F vendor scorecards.', false],
  ['Renewal Management',      'Auto-renewal detection · notice periods · AI recommendations.', false],
  ['Relationship Governance', 'Perception gap analysis · health scoring · improvement points.', true],
  ['Enterprise Security',     'Encryption · role-based access · multi-tenant isolation · audit trails. Certifications on the roadmap.', false],
];

// Risk heatmap data — 10 categories × 4 severities (Low/Med/High/Crit)
const riskCategories = ['Indemnity', 'Liability', 'IP', 'Termination', 'Confidentiality', 'Non-compete', 'Data', 'Insurance', 'Warranty', 'Force majeure'];
const riskMatrix = [
  [4, 12, 8,  2], [3, 9, 14, 5], [6, 11, 5, 1], [2, 7, 11, 3], [8, 14, 6, 0],
  [5, 9, 4, 0],   [1, 6, 13, 7], [7, 10, 5, 1], [3, 8, 9, 2], [4, 6, 3, 1],
];

// Obligation RAG mock rows
const obligations = [
  { id: 'OB-241',  obj: 'Quarterly DPA review',          owner: 'A. Bakker',    due: 'in 4 d', status: 'amber' },
  { id: 'OB-198',  obj: 'Notify of subprocessor change', owner: 'M. de Vries',  due: 'overdue 2 d', status: 'red' },
  { id: 'OB-312',  obj: 'Annual SOC 2 evidence pack',    owner: 'J. Visser',    due: 'in 47 d', status: 'green' },
  { id: 'OB-289',  obj: 'Volume commitment report',      owner: 'L. Smit',      due: 'in 12 d', status: 'amber' },
  { id: 'OB-176',  obj: 'Insurance certificate refresh', owner: 'C. Janssen',   due: 'in 3 d',  status: 'amber' },
];

// SLA scorecard mock
const slaScorecard = [
  { v: 'Acme Telco',        grade: 'B+', compliance: '94.2%', breaches: 12, impact: '€8,400'  },
  { v: 'Vertex Logistics',  grade: 'A-', compliance: '97.8%', breaches: 4,  impact: '€1,200'  },
  { v: 'Lumen Cloud',       grade: 'D',  compliance: '81.3%', breaches: 38, impact: '€42,800' },
  { v: 'Nordic Hosting',    grade: 'A',  compliance: '99.1%', breaches: 1,  impact: '€0'      },
  { v: 'Pacific ITSM',      grade: 'C',  compliance: '88.0%', breaches: 21, impact: '€18,600' },
];

// Perception gap mock
const perceptions = [
  { k: 'Responsiveness',     us: 72, them: 88 },
  { k: 'Quality of delivery', us: 65, them: 81 },
  { k: 'Communication',      us: 70, them: 78 },
  { k: 'Innovation',         us: 58, them: 76 },
  { k: 'Commercial fairness', us: 80, them: 68 },
];

const disciplines = [
  {
    no: '01', title: 'Obligation Tracking',
    summary: 'Every promise tracked, owned, evidenced.',
    body: 'A contract is small promises — delivery, reporting, payment, notice, certification. Most are forgotten by Q3. We find them, hand each to a named owner, stamp the evidence when done.',
    flow: ['Extract', 'Classify (7 types)', 'Assign owner', 'RAG status', 'Evidence & audit'],
    mock: 'rag',
  },
  {
    no: '02', title: 'Risk Detection',
    summary: 'What is buried in the boilerplate.',
    body: 'Indemnities without caps. Termination on twelve hours notice. Confidentiality outliving the deal. Every clause read, scored against ten dimensions, deviations from portfolio norms flagged.',
    flow: ['Parse (OCR)', 'Classify (30+ clauses)', 'Categorise (10 risks)', 'Score severity', 'Portfolio alert'],
    mock: 'heatmap',
  },
  {
    no: '03', title: 'SLA Monitoring',
    summary: 'Recover what you are owed.',
    body: 'Most enterprises pay for service levels they do not actively measure. We extract every SLA term, ingest the real numbers, and count the credits owed before the vendor counts them for you.',
    flow: ['Extract terms', 'Ingest actuals', 'Compare', 'Classify breach', 'Calculate credit'],
    mock: 'scorecard',
  },
  {
    no: '04', title: 'Relationship Governance',
    summary: 'The view from both sides of the table.',
    body: 'Every other CLM stops at the contract. We go into the relationship it is supposed to govern. Dual-perspective scoring reveals the gap between how you see them and how they see you.',
    flow: ['Link orgs', 'Build relationship', 'Score KPIs', 'Detect gaps', 'Improvement points'],
    mock: 'gap',
  },
];

const metrics = [
  { v: '90%',  l: 'Target reduction in contract review time',          w: 'Legal' },
  { v: '3–5×', l: 'Service credits identifiable, vs current claiming', w: 'Procurement' },
  { v: '95%',  l: 'Target reduction in missed deadlines',              w: 'Operations' },
  { v: '1 score', l: 'Composite contract health — Risk · SLA · Obligations rolled up',  w: 'Finance' },
];

const compare = {
  cols: ['Evaluetor', 'DocuSign CLM', 'Icertis', 'Ironclad'],
  rows: [
    ['Time to first outcome',   ['Within weeks',  '6–12 months',  '12–18 months', '3–6 months']],
    ['Native AI agents',        ['Nine',          'Limited',      'Add-on',       'Limited']],
    ['SLA monitoring',          ['Built-in',      'Not standard', 'Add-on',       'Not standard']],
    ['Obligation tracking',     ['AI-extracted',  'Manual',       'Manual',       'Limited']],
    ['Relationship governance', ['Built-in',      'Not standard', 'Not standard', 'Not standard']],
    ['Knowledge graph',         ['Built-in',      'Not standard', 'Not standard', 'Not standard']],
    ['Unlimited users',         ['Yes',           'Per-seat',     'Per-seat',     'Per-seat']],
    ['LLM observability',       ['Langfuse',      'Not standard', 'Not standard', 'Not standard']],
  ],
};

// Deployment timeline comparison (in weeks)
const deploy = [
  { vendor: 'Evaluetor',    weeks: 0.2 },
  { vendor: 'Ironclad',     weeks: 16 },
  { vendor: 'DocuSign CLM', weeks: 36 },
  { vendor: 'Icertis',      weeks: 60 },
];
---

<MarketingLayout
  title="Post-signature contract value — Evaluetor"
  description="Organisations lose 8–11% of contract value after signing. Evaluetor is AI-native CLM, built in the Netherlands, that catches the leakage every other tool misses."
>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap');

  /* ─── Dutch B2B palette ─── */
  :root {
    --paper:    #F7F6F3;
    --paper-2:  #EFEDE8;
    --paper-3:  #E5E2D9;
    --surface:  #FFFFFF;
    --ink:      #0E0E10;
    --ink-2:    #2D2F36;
    --ink-3:    #5B5F66;
    --ink-4:    #A0A4AB;
    --rule:     #1A1A1C;
    --rule-2:   #D8D5CD;
    --rule-3:   #BDBAB1;
    --orange:   #E94E1B;
    --orange-2: #C73E0F;
    --orange-w: #F8D9CB;
    --red:      #B91C1C;
    --amber:    #D97706;
    --green:    #15803D;
  }

  body { background: var(--paper) !important; color: var(--ink); }

  .dutch {
    font-family: 'Geist', system-ui, -apple-system, 'Helvetica Neue', sans-serif;
    color: var(--ink);
    font-feature-settings: 'ss01' 1, 'kern' 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .dutch .mono    { font-family: 'Geist Mono', 'IBM Plex Mono', ui-monospace, monospace; font-feature-settings: 'ss02' 1; }
  .dutch .ink     { color: var(--ink); }
  .dutch .ink-2   { color: var(--ink-2); }
  .dutch .ink-3   { color: var(--ink-3); }
  .dutch .ink-4   { color: var(--ink-4); }
  .dutch .orange  { color: var(--orange); }

  /* ─── Typography ─── */
  .display   { font-family: 'Geist', sans-serif; font-weight: 500; letter-spacing: -0.025em; line-height: 1.0; }
  .display-xl { font-size: clamp(40px, 5.4vw, 76px); }
  .display-lg { font-size: clamp(34px, 4.6vw, 64px); }
  .display-md { font-size: clamp(26px, 3.0vw, 40px); }

  /* ─── Italic emphasis (Ironclad/Luminance punch-word pattern) ─── */
  .emph {
    font-family: 'Instrument Serif', Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .emph-sans {
    font-style: italic;
    font-weight: 400;
  }

  /* ─── Huge discipline numeral ─── */
  .numeral-huge {
    font-family: 'Geist', sans-serif;
    font-size: clamp(72px, 9vw, 132px);
    font-weight: 300;
    letter-spacing: -0.04em;
    line-height: 0.82;
    color: var(--orange);
    font-variant-numeric: tabular-nums;
  }
  .display-sm { font-size: clamp(18px, 1.8vw, 22px); font-weight: 600; }

  .lead { font-size: clamp(17px, 1.3vw, 20px); line-height: 1.55; color: var(--ink-2); }

  .label {
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-3);
  }
  .label-ink    { color: var(--ink); }
  .label-orange { color: var(--orange); }
  .tnum { font-variant-numeric: tabular-nums; }

  /* ─── Rules ─── */
  .rule       { border-top: 1px solid var(--rule); }
  .rule-soft  { border-top: 1px solid var(--rule-2); }
  .rule-thick { border-top: 3px solid var(--rule); }
  .rule-ora   { border-top: 3px solid var(--orange); }

  /* ─── Section frame ─── */
  .section       { padding: clamp(48px, 4.8vw, 72px) 0; }
  .section-tight { padding: clamp(36px, 3.4vw, 56px) 0; }
  .wrap { max-width: 84rem; padding-left: 20px; padding-right: 20px; margin-left: auto; margin-right: auto; }
  @media (min-width: 768px) { .wrap { padding-left: 32px; padding-right: 32px; } }
  @media (min-width: 1280px) { .wrap { padding-left: 48px; padding-right: 48px; } }

  /* ─── Scroll reveal ─── */
  .sr { opacity: 0; transform: translateY(10px); transition: opacity .6s cubic-bezier(.2,.7,.2,1), transform .6s cubic-bezier(.2,.7,.2,1); }
  .sr.in { opacity: 1; transform: none; }

  .stagger > * { opacity: 0; transform: translateY(8px); animation: in 0.7s cubic-bezier(.2,.7,.2,1) forwards; }
  .stagger > *:nth-child(1) { animation-delay: .05s; }
  .stagger > *:nth-child(2) { animation-delay: .12s; }
  .stagger > *:nth-child(3) { animation-delay: .22s; }
  .stagger > *:nth-child(4) { animation-delay: .34s; }
  .stagger > *:nth-child(5) { animation-delay: .48s; }
  @keyframes in { to { opacity: 1; transform: none; } }

  /* ─── Sectionhead grammar ─── */
  .sechead { display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px; align-items: baseline; padding-bottom: 16px; border-bottom: 1px solid var(--rule); }
  .sechead-num { grid-column: span 12; }
  .sechead-h   { grid-column: span 12; }
  @media (min-width: 768px) {
    .sechead-num { grid-column: span 3; }
    .sechead-h   { grid-column: span 9; }
  }

  /* ─── Lifecycle timeline ─── */
  .tl { position: relative; height: 140px; border: 1px solid var(--rule); background: var(--surface); }
  .tl-region {
    position: absolute; top: 0; bottom: 0;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 14px 18px;
  }
  .tl-region.exec {
    background: var(--ink); color: var(--paper);
    border-left: 1px solid var(--rule); border-right: 1px solid var(--rule);
  }
  .tl-region.exec::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--orange);
  }
  .tl-region .label { color: inherit; opacity: 0.6; }
  .tl-region.exec .label { color: var(--orange); opacity: 1; }
  .tl-event {
    position: absolute; bottom: -38px;
    transform: translateX(-50%);
    font-family: 'Geist Mono', monospace;
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--ink-3); white-space: nowrap;
  }
  .tl-event::before {
    content: ''; display: block;
    width: 1px; height: 14px; background: var(--ink-3);
    margin: 0 auto 6px;
  }
  .tl-event.hi::before { background: var(--orange); height: 18px; }
  .tl-event.hi { color: var(--orange); }
  .tl-axis {
    margin-top: 56px;
    display: flex; justify-content: space-between;
    font-family: 'Geist Mono', monospace; font-size: 10px;
    color: var(--ink-3); letter-spacing: 0.06em;
  }

  /* ─── Connector card ─── */
  .conn {
    background: var(--surface);
    border: 1px solid var(--rule-2);
    padding: 18px 20px;
  }
  .conn-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
  .conn-table td { padding: 7px 0; border-bottom: 1px solid var(--rule-2); font-size: 13px; }
  .conn-table td:first-child { color: var(--ink-3); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.04em; text-transform: uppercase; }
  .conn-table td:last-child  { text-align: right; font-weight: 500; color: var(--ink); font-variant-numeric: tabular-nums; }
  .conn-table tr:last-child td { border-bottom: 0; }

  /* ─── Capability list ─── */
  .cap-row { display: grid; grid-template-columns: 28px 1fr; gap: 14px; padding: 14px 0; border-top: 1px solid var(--rule-2); }
  .cap-row:last-child { border-bottom: 1px solid var(--rule-2); }
  .cap-num { font-family: 'Geist Mono', monospace; font-size: 10.5px; color: var(--ink-3); letter-spacing: 0.08em; padding-top: 3px; }
  .cap-t { font-size: 16px; font-weight: 500; color: var(--ink); display: flex; align-items: center; flex-wrap: wrap; gap: 8px; }
  .cap-d { font-size: 13px; color: var(--ink-3); margin-top: 3px; line-height: 1.5; }
  .ex-tag {
    display: inline-block;
    font-family: 'Geist Mono', monospace;
    font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--orange);
    padding: 1px 7px; border: 1px solid var(--orange);
  }

  /* ─── Comparison table ─── */
  .ctable { width: 100%; border-collapse: collapse; }
  .ctable thead th {
    text-align: left;
    font-family: 'Geist Mono', monospace; font-weight: 500;
    font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink-3); padding: 12px 14px 10px 0;
    border-bottom: 1px solid var(--rule); vertical-align: bottom;
  }
  .ctable thead th.us {
    color: var(--ink); font-family: 'Geist', sans-serif;
    font-size: 15px; text-transform: none; letter-spacing: 0;
    font-weight: 600; padding-right: 18px;
  }
  .ctable thead th.us::before {
    content: ''; display: inline-block;
    width: 6px; height: 6px; background: var(--orange);
    margin-right: 8px; transform: translateY(-2px);
  }
  .ctable tbody td {
    padding: 13px 14px 13px 0;
    border-bottom: 1px solid var(--rule-2);
    vertical-align: top; font-size: 14px;
  }
  .ctable tbody tr td:first-child { color: var(--ink); font-weight: 500; }
  .ctable tbody td.us { color: var(--ink); font-weight: 600; padding-right: 18px; }
  .ctable tbody td.them { color: var(--ink-3); }
  .ctable tbody tr:last-child td { border-bottom: 0; }
  .ctable tbody tr.zebra td { background: var(--paper-2); }

  /* ═════ MOCK UI: RAG dashboard ═════ */
  .mock { background: var(--surface); border: 1px solid var(--rule-2); padding: 0; }
  .mock-head { display: flex; justify-content: space-between; align-items: baseline; padding: 10px 14px; border-bottom: 1px solid var(--rule-2); background: var(--paper-2); }
  .mock-head .ttl { font-size: 12px; font-weight: 600; }
  .mock-head .meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--ink-3); letter-spacing: 0.06em; }
  .rag-row { display: grid; grid-template-columns: 8px 56px 1fr 100px 80px; gap: 10px; align-items: center; padding: 9px 14px; border-bottom: 1px solid var(--rule-2); font-size: 12px; }
  .rag-row:last-child { border-bottom: 0; }
  .rag-dot { width: 8px; height: 8px; border-radius: 50%; }
  .rag-dot.red   { background: var(--red); }
  .rag-dot.amber { background: var(--amber); }
  .rag-dot.green { background: var(--green); }
  .rag-id { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--ink-3); }
  .rag-obj { color: var(--ink); }
  .rag-owner { color: var(--ink-3); font-size: 11px; }
  .rag-due { text-align: right; font-variant-numeric: tabular-nums; font-size: 11px; }
  .rag-due.red { color: var(--red); font-weight: 600; }
  .rag-due.amber { color: var(--amber); font-weight: 600; }
  .rag-due.green { color: var(--green); }

  /* ═════ MOCK UI: Risk heatmap ═════ */
  .heat-wrap { padding: 14px; }
  .heat-grid { display: grid; grid-template-columns: 110px repeat(4, 1fr); gap: 2px; }
  .heat-h { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--ink-3); letter-spacing: 0.08em; text-transform: uppercase; padding: 6px 8px; text-align: center; }
  .heat-h.first { text-align: left; }
  .heat-l { font-size: 11px; color: var(--ink); padding: 6px 8px; display: flex; align-items: center; background: var(--paper-2); }
  .heat-c { font-family: 'Geist Mono', monospace; font-size: 11px; text-align: center; padding: 6px 4px; color: var(--ink); font-variant-numeric: tabular-nums; }

  /* ═════ MOCK UI: SLA scorecard ═════ */
  .sla-row { display: grid; grid-template-columns: 1fr 36px 64px 50px 80px; gap: 10px; align-items: center; padding: 9px 14px; border-bottom: 1px solid var(--rule-2); font-size: 12px; }
  .sla-row:last-child { border-bottom: 0; }
  .sla-row.head { background: var(--paper-2); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-3); }
  .sla-row.head > * { font-weight: 500; }
  .sla-row.head > *:nth-child(n+2) { text-align: right; }
  .sla-grade { font-weight: 700; text-align: right; }
  .sla-grade.A { color: var(--green); }
  .sla-grade.B { color: var(--ink); }
  .sla-grade.C { color: var(--amber); }
  .sla-grade.D { color: var(--red); }
  .sla-num  { font-variant-numeric: tabular-nums; text-align: right; }

  /* ═════ MOCK UI: Perception gap ═════ */
  .gap-row { padding: 10px 14px; border-bottom: 1px solid var(--rule-2); }
  .gap-row:last-child { border-bottom: 0; }
  .gap-top { display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 6px; }
  .gap-name { color: var(--ink); font-weight: 500; }
  .gap-delta { font-family: 'Geist Mono', monospace; color: var(--orange); font-size: 10px; }
  .gap-delta.pos { color: var(--green); }
  .gap-track { position: relative; height: 8px; background: var(--paper-2); }
  .gap-bar { position: absolute; top: 0; bottom: 0; }
  .gap-us { background: var(--ink); }
  .gap-them { background: var(--orange); opacity: 0.55; }
  .gap-legend { display: flex; gap: 16px; font-family: 'Geist Mono', monospace; font-size: 10px; padding: 8px 14px; color: var(--ink-3); letter-spacing: 0.06em; }
  .gap-legend .sw { display: inline-block; width: 10px; height: 10px; margin-right: 6px; vertical-align: -1px; }

  /* ═════ Deployment timeline bars ═════ */
  .dep-row { display: grid; grid-template-columns: 130px 1fr 70px; gap: 14px; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--rule-2); }
  .dep-row:last-child { border-bottom: 0; }
  .dep-name { font-size: 13px; font-weight: 500; }
  .dep-name.us { color: var(--ink); }
  .dep-track { background: var(--paper-2); height: 10px; position: relative; }
  .dep-fill { position: absolute; top: 0; bottom: 0; left: 0; }
  .dep-fill.us { background: var(--orange); }
  .dep-fill.them { background: var(--ink); }
  .dep-num { font-family: 'Geist Mono', monospace; font-size: 11px; text-align: right; color: var(--ink); font-variant-numeric: tabular-nums; }

  /* ─── CTA ─── */
