---
import MarketingLayout from '../layouts/MarketingLayout.astro';

// ─── Content ──────────────────────────────────────────────────────────────

const leakages = [
  ['Off-contract spend',         'Procurement bought outside negotiated terms.'],
  ['Pricing & discount control', 'Discounts applied incorrectly or unchecked.'],
  ['Unclaimed rebates',          'Volume rebates and credits never claimed.'],
  ['Visibility gaps',            'No one knows what is in the contract base.'],
  ['Scope creep',                'Additional work delivered, never repriced.'],
  ['Unenforced SLAs',            'Breaches detected late, credits never billed.'],
  ['Accidental renewals',        'Auto-renewals fired before notice given.'],
  ['Forecast errors',            'Volume commitments missed or oversold.'],
  ['Legal–commercial drift',     'Signed terms diverge from operational reality.'],
  ['No single owner',            'No one accountable for value realisation.'],
];

const principles = [
  ['Contract ≠ Document',                       'Data, obligations and risk — not a PDF.'],
  ['Post-signature is the value zone',          '70–80% of leakage happens after signing.'],
  ['Business owns value. Legal owns integrity.','Separated responsibilities, written down.'],
  ['One contract truth',                        'A single source across every system.'],
  ['No unmanaged deviations',                   'Every change priced, approved, logged.'],
  ['Value is measured, not assumed',            'Realised outcomes against negotiated terms.'],
];

const timelineEvents = [
  { at: 8,  label: 'Scope change',     loss: 'low' },
  { at: 15, label: 'SLA breach',       loss: 'high' },
  { at: 19, label: 'Missed deadline',  loss: 'mid' },
  { at: 24, label: 'Volume miss',      loss: 'mid' },
  { at: 28, label: 'Unclaimed credit', loss: 'high' },
