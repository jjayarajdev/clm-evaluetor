---
import PricingCard from './PricingCard.astro';
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-4 items-start">
  <PricingCard
    name="Starter"
    price="$1,500"
    description="For teams getting started with contract intelligence"
    features={[
      'Up to 100 contracts',
      'AI metadata extraction',
      'Clause & risk analysis',
      'Obligation tracking',
      'Basic dashboards',
      'Email support',
    ]}
  />
  <PricingCard
    name="Professional"
    price="$4,000"
    description="For growing teams that need compliance & SLA tracking"
    highlighted={true}
    features={[
      'Up to 500 contracts',
      'Everything in Starter',
      'SLA monitoring & alerts',
      'Renewal management',
      'Compliance reports',
      'Vendor performance scoring',
      '2 integrations',
      'Priority support',
    ]}
  />
  <PricingCard
    name="Enterprise"
    price="$10,000"
    description="For organizations needing full governance capabilities"
    features={[
      'Up to 2,000 contracts',
      'Everything in Professional',
      'Relationship governance',
      'KPI perception scoring',
      'Satisfaction surveys',
      'API access & SSO',
      'Custom workflows',
      'Dedicated success manager',
    ]}
  />
  <PricingCard
    name="Strategic"
    price="Custom"
    period=""
    description="For enterprises with complex needs"
    cta={{ text: 'Contact Sales', href: '/contact' }}
    features={[
      'Unlimited contracts',
      'Everything in Enterprise',
      'Custom AI training',
      'On-premise deployment',
      'SLA guarantee',
      'Custom integrations',
      'Executive business reviews',
    ]}
  />
</div>
