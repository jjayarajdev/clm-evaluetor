---
interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
  dark?: boolean;
}

const { tag, title, subtitle, centered = true, dark = false } = Astro.props;
---

<div class={`mb-12 ${centered ? 'text-center' : ''}`}>
  {tag && (
    <p class={`text-base font-semibold uppercase tracking-wider mb-3 ${dark ? 'text-primary-400' : 'text-primary-600'}`}>{tag}</p>
  )}

  {/* Decorative gradient accent line */}
  {centered && (
    <div class="flex justify-center mb-5">
      <div class="w-12 h-0.5 rounded-full bg-gradient-to-r from-primary-500 to-pink-500"></div>
    </div>
  )}
  {!centered && (
    <div class="mb-5">
      <div class="w-12 h-0.5 rounded-full bg-gradient-to-r from-primary-500 to-pink-500"></div>
    </div>
  )}

  <h2 class={`text-4xl sm:text-5xl font-bold tracking-tight ${dark ? 'text-white' : 'text-gray-900'}`}>{title}</h2>
  {subtitle && (
    <p class={`mt-5 text-xl ${dark ? 'text-gray-400' : 'text-gray-600'} ${centered ? 'max-w-3xl mx-auto' : 'max-w-3xl'}`}>{subtitle}</p>
  )}
</div>
