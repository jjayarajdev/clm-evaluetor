---
interface Props {
  title: string;
  description: string;
  bullets?: string[];
  imagePosition?: 'left' | 'right';
  tag?: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, bullets = [], imagePosition = 'right', tag, image, imageAlt = '' } = Astro.props;
---

<div class={`flex flex-col lg:flex-row items-center gap-12 lg:gap-16 ${imagePosition === 'left' ? 'lg:flex-row-reverse' : ''}`}>
  <!-- Text side -->
  <div class="flex-1">
    {tag && (
      <p class="text-base font-semibold text-primary-600 uppercase tracking-wider mb-3">{tag}</p>
    )}
    <h3 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{title}</h3>
    <p class="text-lg text-gray-600 leading-relaxed mb-6">{description}</p>
    {bullets.length > 0 && (
      <ul class="space-y-3">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
            <span class="text-base text-gray-700">{bullet}</span>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Visual side -->
  <div class="flex-1 w-full">
    {image ? (
      <div class="rounded-2xl overflow-hidden shadow-2xl shadow-primary-500/10 border border-gray-200/60">
        <img src={image} alt={imageAlt || title} class="w-full h-auto" loading="lazy" />
      </div>
    ) : (
      <div class="bg-gradient-to-br from-primary-100 to-primary-50 rounded-2xl p-8 aspect-[4/3] flex items-center justify-center">
        <slot>
          <div class="text-center text-primary-400">
            <svg class="w-16 h-16 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" /></svg>
            <p class="text-sm">Product Screenshot</p>
          </div>
        </slot>
      </div>
    )}
  </div>
</div>
