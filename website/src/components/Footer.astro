---
const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Overview',                 href: '/product' },
      { label: 'Contract Intelligence',    href: '/features/contract-intelligence' },
      { label: 'Obligation Tracking',      href: '/features/obligation-tracking' },
      { label: 'SLA Monitoring',           href: '/features/sla-monitoring' },
      { label: 'Renewal Management',       href: '/features/renewal-management' },
      { label: 'Relationship Governance',  href: '/features/relationship-governance' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'Why Evaluetor',  href: '/commercial' },
      { label: 'Platform',       href: '/platform' },
      { label: 'Who it\'s for',  href: '/who-its-for' },
      { label: 'How we engage',  href: '/engage' },
      { label: 'About',          href: '/about' },
      { label: 'Contact',        href: '/contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy',    href: '/legal/privacy' },
      { label: 'Terms of Service',  href: '/legal/terms' },
    ],
  },
];
---

<footer style="background: var(--paper-2); border-top: 1px solid var(--rule);">
  <div class="wrap" style="padding-top: 56px; padding-bottom: 32px;">
    <div class="grid grid-cols-2 md:grid-cols-4" style="gap: 32px;">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5" style="text-decoration: none; margin-bottom: 16px;">
          <div style="width: 32px; height: 32px; background: var(--ink); display: flex; align-items: center; justify-content: center;">
            <span style="color: var(--paper); font-family: 'Geist', sans-serif; font-weight: 700; font-size: 16px;">E</span>
          </div>
          <span style="font-family: 'Geist', sans-serif; font-weight: 600; font-size: 18px; color: var(--ink); letter-spacing: -0.01em;">
            Evaluetor
          </span>
        </a>

        <p class="ink-2" style="font-size: 14px; line-height: 1.55; max-width: 260px; margin-bottom: 16px;">
          AI-native contract lifecycle management. Built in <em class="emph" style="color: var(--ink);">the Netherlands</em>.
        </p>

        <div class="label">
          Evaluetor B.V. &nbsp;·&nbsp; the Netherlands
        </div>
      </div>

      <!-- Link columns -->
      {columns.map((column) => (
        <div>
          <div class="label label-ink" style="margin-bottom: 14px;">{column.title}</div>
          <ul style="list-style: none; padding: 0; margin: 0;">
            {column.links.map((link) => (
              <li style="margin-bottom: 8px;">
                <a href={link.href} class="dfoot-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="rule-soft flex flex-col sm:flex-row justify-between items-start sm:items-center" style="margin-top: 48px; padding-top: 22px; gap: 12px;">
      <p class="mono" style="font-size: 11px; color: var(--ink-3); letter-spacing: 0.04em;">
        &copy; 2026 Evaluetor B.V. &nbsp;·&nbsp; All rights reserved.
      </p>
      <a href="mailto:sales@evaluetor.com" class="dfoot-link" style="font-size: 13px;">
        sales@evaluetor.com
      </a>
    </div>
  </div>
</footer>

<style is:global>
  .dfoot-link {
    font-family: 'Geist', sans-serif;
    font-size: 14px;
    color: var(--ink-3);
    text-decoration: none;
    transition: color .15s ease;
  }
  .dfoot-link:hover { color: var(--orange-2); }
</style>
