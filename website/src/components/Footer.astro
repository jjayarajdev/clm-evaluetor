---
const columns = [
  {
    title: 'Product',
    links: [
      { label: 'Product Overview', href: '/product' },
      { label: 'Contract Intelligence', href: '/features/contract-intelligence' },
      { label: 'Obligation Tracking', href: '/features/obligation-tracking' },
      { label: 'SLA Monitoring', href: '/features/sla-monitoring' },
      { label: 'Renewal Management', href: '/features/renewal-management' },
      { label: 'Relationship Governance', href: '/features/relationship-governance' },
      { label: 'Pricing', href: '/pricing' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'About', href: '/about' },
      { label: 'Customers', href: '/customers' },
      { label: 'Platform', href: '/platform' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/legal/privacy' },
      { label: 'Terms of Service', href: '/legal/terms' },
    ],
  },
];
---

<footer class="bg-[#0a0a0f] text-gray-300 border-t border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1 relative">
        <div class="absolute -top-16 -left-16 w-64 h-64 bg-primary-500/10 rounded-full blur-3xl pointer-events-none"></div>
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary-500 rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">E</span>
          </div>
          <span class="text-xl font-bold text-white">Evaluetor</span>
        </a>
        <p class="text-sm text-gray-400 mb-4 max-w-xs">
          Making contracts less terrible, one AI agent at a time.
        </p>
        <div class="flex items-center gap-2 text-sm text-gray-500">
          <span>By Senority B.V.</span>
          <span>&middot;</span>
          <span>Rotterdam, NL</span>
        </div>
      </div>

      <!-- Link columns -->
      {columns.map((column) => (
        <div>
          <h3 class="text-sm font-semibold text-white mb-4">{column.title}</h3>
          <ul class="space-y-2.5">
            {column.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">&copy; 2026 Evaluetor. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="mailto:sales@evaluetor.com" class="text-sm text-gray-400 hover:text-white transition-colors">
          sales@evaluetor.com
        </a>
      </div>
    </div>
  </div>
</footer>
