---
interface Props {
  heading?: string;
}

const { heading = 'Get in Touch' } = Astro.props;
---

<form class="space-y-5" action="https://formspree.io/f/placeholder" method="POST">
  <h3 class="text-xl font-bold text-gray-900">{heading}</h3>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
      <input type="text" id="name" name="name" required class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm" />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Work Email</label>
      <input type="email" id="email" name="email" required class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm" />
    </div>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company</label>
      <input type="text" id="company" name="company" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm" />
    </div>
    <div>
      <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Role</label>
      <select id="role" name="role" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm bg-white">
        <option value="">Select...</option>
        <option value="legal">General Counsel / Legal</option>
        <option value="procurement">Procurement / CPO</option>
        <option value="finance">Finance / CFO</option>
        <option value="it">IT / CTO</option>
        <option value="operations">Operations / COO</option>
        <option value="other">Other</option>
      </select>
    </div>
  </div>
  <div>
    <label for="contracts" class="block text-sm font-medium text-gray-700 mb-1">Active Contracts</label>
    <select id="contracts" name="contracts" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm bg-white">
      <option value="">Select...</option>
      <option value="1-50">1-50</option>
      <option value="51-100">51-100</option>
      <option value="101-500">101-500</option>
      <option value="500+">500+</option>
    </select>
  </div>
  <div>
    <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
    <textarea id="message" name="message" rows="4" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-sm"></textarea>
  </div>
  <button type="submit" class="btn-primary w-full sm:w-auto">
    Send Message
  </button>
</form>
