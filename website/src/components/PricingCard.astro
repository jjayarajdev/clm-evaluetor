---
interface Props {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  cta?: { text: string; href: string };
  highlighted?: boolean;
}

const {
  name,
  price,
  period = '/month',
  description,
  features,
  cta = { text: 'Get Started', href: '/contact' },
  highlighted = false,
} = Astro.props;
---

<div class={`relative rounded-2xl p-8 ${highlighted ? 'bg-primary-700 text-white ring-2 ring-primary-600 shadow-xl scale-105' : 'bg-white border border-gray-200'}`}>
  {highlighted && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-primary-500 text-white text-xs font-semibold rounded-full">
      Most Popular
    </div>
  )}
  <h3 class={`text-lg font-semibold ${highlighted ? 'text-white' : 'text-gray-900'}`}>{name}</h3>
  <p class={`mt-1 text-sm ${highlighted ? 'text-primary-200' : 'text-gray-500'}`}>{description}</p>
  <div class="mt-6 flex items-baseline gap-1">
    <span class={`text-4xl font-bold ${highlighted ? 'text-white' : 'text-gray-900'}`}>{price}</span>
    {period && <span class={`text-sm ${highlighted ? 'text-primary-200' : 'text-gray-500'}`}>{period}</span>}
  </div>
  <a
    href={cta.href}
    class={`mt-6 block w-full text-center py-2.5 text-sm font-semibold rounded-lg transition-colors ${
      highlighted
        ? 'bg-white text-primary-700 hover:bg-primary-50'
        : 'bg-primary-600 text-white hover:bg-primary-700'
    }`}
  >
    {cta.text}
  </a>
  <ul class="mt-8 space-y-3">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class={`w-5 h-5 mt-0.5 flex-shrink-0 ${highlighted ? 'text-primary-300' : 'text-primary-600'}`} fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
        <span class={`text-sm ${highlighted ? 'text-primary-100' : 'text-gray-600'}`}>{feature}</span>
      </li>
    ))}
  </ul>
</div>
