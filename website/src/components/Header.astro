---
const navItems = [
  {
    label: 'Product',
    href: '/product',
    children: [
      { label: 'Contract Intelligence',    href: '/features/contract-intelligence' },
      { label: 'Obligation Tracking',      href: '/features/obligation-tracking' },
      { label: 'SLA Monitoring',           href: '/features/sla-monitoring' },
      { label: 'Renewal Management',       href: '/features/renewal-management' },
      { label: 'Relationship Governance',  href: '/features/relationship-governance' },
    ],
  },
  { label: 'Why Evaluetor', href: '/commercial' },
  { label: 'Platform',      href: '/platform' },
  { label: 'Who it\'s for', href: '/who-its-for' },
  { label: 'How we engage', href: '/engage' },
  { label: 'About',         href: '/about' },
];
---

<header class="dutch-nav fixed top-0 left-0 right-0 z-50">
  <nav class="wrap">
    <div class="flex items-center justify-between" style="height: 64px;">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5" style="text-decoration: none;">
        <div style="width: 32px; height: 32px; background: var(--ink); display: flex; align-items: center; justify-content: center;">
          <span style="color: var(--paper); font-family: 'Geist', sans-serif; font-weight: 700; font-size: 16px;">E</span>
        </div>
        <span style="font-family: 'Geist', sans-serif; font-weight: 600; font-size: 18px; color: var(--ink); letter-spacing: -0.01em;">
          Evaluetor
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center" style="gap: 6px;">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <button class="dnav-link" type="button">
                {item.label}
                <svg style="width: 11px; height: 11px; margin-left: 4px;" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
              </button>
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150">
                <div style="background: var(--surface); border: 1px solid var(--rule-2); min-width: 260px; padding: 6px 0;">
                  {item.children.map((child) => (
                    <a href={child.href} class="dnav-child">{child.label}</a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a href={item.href} class="dnav-link">{item.label}</a>
          )
        ))}
      </div>

      <!-- CTA + mobile toggle -->
      <div class="flex items-center" style="gap: 12px;">
        <a href="/contact" class="hidden sm:inline-flex cta-btn" style="padding: 9px 16px; font-size: 14px;">
          Book a review <span class="arr">→</span>
        </a>
        <button id="mobile-menu-btn" class="md:hidden" style="padding: 6px; color: var(--ink); background: transparent; border: none;">
          <svg style="width: 22px; height: 22px;" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="background: var(--paper); border-top: 1px solid var(--rule-2);">
    <div class="wrap" style="padding-top: 14px; padding-bottom: 18px;">
      {navItems.map((item) => (
        item.children ? (
          <div style="margin-bottom: 12px;">
            <a href={item.href} class="dnav-mlink" style="font-weight: 600;">{item.label}</a>
            <div style="padding-left: 12px;">
              {item.children.map((child) => (
                <a href={child.href} class="dnav-mlink-child">{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="dnav-mlink">{item.label}</a>
        )
      ))}
      <a href="/contact" class="cta-btn" style="margin-top: 14px; width: 100%; justify-content: center;">
        Book a review <span class="arr">→</span>
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div style="height: 64px;"></div>

<style is:global>
  .dnav-link {
    display: inline-flex; align-items: center;
    padding: 8px 14px;
    font-family: 'Geist', sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--ink-2);
    background: transparent; border: none;
    text-decoration: none;
    transition: color .15s ease;
    cursor: pointer;
    letter-spacing: -0.005em;
  }
  .dnav-link:hover { color: var(--orange-2); }

  .dnav-child {
    display: block;
    padding: 9px 16px;
    font-family: 'Geist', sans-serif;
    font-size: 13.5px;
    color: var(--ink-2);
    text-decoration: none;
    transition: background .12s ease, color .12s ease;
  }
  .dnav-child:hover { background: var(--paper-2); color: var(--orange-2); }

  .dnav-mlink {
    display: block;
    padding: 9px 0;
    font-family: 'Geist', sans-serif;
    font-size: 15px;
    color: var(--ink);
    text-decoration: none;
  }
  .dnav-mlink-child {
    display: block;
    padding: 7px 0;
    font-family: 'Geist', sans-serif;
    font-size: 14px;
    color: var(--ink-3);
    text-decoration: none;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
