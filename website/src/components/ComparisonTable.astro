---
const capabilities = [
  { feature: 'Time to Value', evaluetor: 'Hours', docusign: '6-12 months', icertis: '12-18 months', ironclad: '3-6 months' },
  { feature: 'Pricing Model', evaluetor: 'Contract volume', docusign: 'Per-seat', icertis: 'Per-seat', ironclad: 'Per-seat' },
  { feature: 'AI Extraction', evaluetor: 'Native GPT-4o', docusign: 'Limited', icertis: 'Add-on', ironclad: 'Limited' },
  { feature: 'SLA Monitoring', evaluetor: 'Built-in', docusign: 'No', icertis: 'Add-on', ironclad: 'No' },
  { feature: 'Relationship Governance', evaluetor: 'Built-in', docusign: 'No', icertis: 'No', ironclad: 'No' },
  { feature: 'Unlimited Users', evaluetor: 'Yes', docusign: 'No', icertis: 'No', ironclad: 'No' },
  { feature: 'Obligation Tracking', evaluetor: 'AI + Manual', docusign: 'Manual only', icertis: 'AI + Manual', ironclad: 'Manual only' },
  { feature: 'Vendor Scoring', evaluetor: 'Multi-factor', docusign: 'No', icertis: 'Basic', ironclad: 'No' },
];
---

<div class="overflow-x-auto rounded-2xl border border-white/10 bg-gray-950">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-white/10 bg-white/[0.03]">
        <th class="text-left py-4 px-5 font-semibold text-gray-300">Capability</th>
        <th class="text-center py-4 px-5 font-semibold text-primary-400 bg-primary-500/10 border-x border-primary-500/20">Evaluetor</th>
        <th class="text-center py-4 px-5 font-medium text-gray-500">DocuSign CLM</th>
        <th class="text-center py-4 px-5 font-medium text-gray-500">Icertis</th>
        <th class="text-center py-4 px-5 font-medium text-gray-500">Ironclad</th>
      </tr>
    </thead>
    <tbody>
      {capabilities.map((row, i) => (
        <tr class={`border-b border-white/[0.06] ${i % 2 === 0 ? 'bg-white/[0.02]' : ''} hover:bg-white/[0.04] transition-colors`}>
          <td class="py-3.5 px-5 font-medium text-gray-300">{row.feature}</td>
          <td class="py-3.5 px-5 text-center bg-primary-500/[0.08] border-x border-primary-500/20 font-semibold text-primary-400">{row.evaluetor}</td>
          <td class="py-3.5 px-5 text-center text-gray-500">{row.docusign}</td>
          <td class="py-3.5 px-5 text-center text-gray-500">{row.icertis}</td>
          <td class="py-3.5 px-5 text-center text-gray-500">{row.ironclad}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
